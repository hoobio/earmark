<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Earmark.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Earmark.App"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    xmlns:converters="using:Earmark.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="ContentSurfaceBrush" Color="{ThemeResource SystemBaseLowColor}" Opacity="0.55" />
                    <!-- Now-playing artwork scrim: a theme-aware translucent veil so the card's standard
                         theme-coloured text/controls stay legible over the art while the art shows through.
                         Dark veil in dark theme (light text), light veil in light theme (dark text); a
                         solid window colour under High Contrast. WinUI has no built-in adaptive scrim, so
                         this is the one place a brush is defined; everything on top uses theme brushes. -->
                    <SolidColorBrush x:Key="NowPlayingScrimBrush" Color="#000000" Opacity="0.50" />
                    <!-- Now-playing frost: an in-app acrylic laid over low-res artwork so the compositor
                         blurs it into a soft, album-coloured backdrop (replaces the old Win2D Gaussian).
                         Dark, low-luminosity frost in dark theme; brighter frost in light. TintOpacity is
                         kept low so the art's colour survives; TintLuminosityOpacity does the theme split.
                         Falls back to FallbackColor when transparency is off / battery saver / low-end. -->
                    <media:AcrylicBrush x:Key="NowPlayingFrostBrush"
                                        TintColor="#000000" TintOpacity="0.40" TintLuminosityOpacity="0.55"
                                        FallbackColor="#1C1C1C" />
                    <!-- Card surface, theme-aware. Dark keeps the original subtle, borderless layer fill
                         (a hard card fill + stroke reads too light/boxy over dark Mica). Light needs the
                         standard card fill + hairline to separate from the near-white Mica backdrop. -->
                    <SolidColorBrush x:Key="SectionCardBackgroundBrush" Color="{ThemeResource LayerFillColorDefault}" />
                    <SolidColorBrush x:Key="SectionCardBorderBrush" Color="Transparent" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ContentSurfaceBrush" Color="{ThemeResource SystemBaseLowColor}" Opacity="0.45" />
                    <SolidColorBrush x:Key="NowPlayingScrimBrush" Color="#FFFFFF" Opacity="0.80" />
                    <media:AcrylicBrush x:Key="NowPlayingFrostBrush"
                                        TintColor="#FFFFFF" TintOpacity="0.30" TintLuminosityOpacity="0.65"
                                        FallbackColor="#E8E8E8" />
                    <SolidColorBrush x:Key="SectionCardBackgroundBrush" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                    <SolidColorBrush x:Key="SectionCardBorderBrush" Color="{ThemeResource CardStrokeColorDefault}" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="ContentSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="NowPlayingScrimBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="NowPlayingFrostBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="SectionCardBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="SectionCardBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:NullableToVisibilityConverter x:Key="NullableToVisibilityConverter" />
            <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
            <converters:SatisfiedGlyphConverter x:Key="SatisfiedGlyphConverter" />
            <converters:SatisfiedBrushConverter x:Key="SatisfiedBrushConverter" />
            <converters:SatisfiedTooltipConverter x:Key="SatisfiedTooltipConverter" />
            <converters:QuickPinBrushConverter x:Key="QuickPinBrushConverter" />
            <converters:WaveLinkStateBrushConverter x:Key="WaveLinkStateBrushConverter" />
            <converters:WaveLinkStateGlyphConverter x:Key="WaveLinkStateGlyphConverter" />
            <converters:NegatedBooleanConverter x:Key="NegatedBooleanConverter" />
            <converters:NegatedBooleanToVisibilityConverter x:Key="NegatedBooleanToVisibilityConverter" />
            <converters:VolumeFloatToPercentConverter x:Key="VolumeFloatToPercentConverter" />
            <converters:MutedBrushConverter x:Key="MutedBrushConverter" />
            <converters:MuteLockedBackgroundConverter x:Key="MuteLockedBackgroundConverter" />
            <converters:PeakLevelToBrushConverter x:Key="PeakLevelToBrushConverter" />
            <converters:SecondsToTimestampConverter x:Key="SecondsToTimestampConverter" />

            <!-- Fluent 2 spacing scale (4px grid). size20/40/80/120/160/200/240/320. -->
            <x:Double x:Key="SpacingXXSmall">2</x:Double>
            <x:Double x:Key="SpacingXSmall">4</x:Double>
            <x:Double x:Key="SpacingSmall">8</x:Double>
            <x:Double x:Key="SpacingMedium">12</x:Double>
            <x:Double x:Key="SpacingLarge">16</x:Double>
            <x:Double x:Key="SpacingXLarge">24</x:Double>
            <x:Double x:Key="SpacingXXLarge">32</x:Double>

            <!-- Fluent 2 corner radii: 4 for inset controls/chips, 8 for cards/containers/tiles.
                 ControlCornerRadius (4) is a built-in WinUI theme resource; CardCornerRadius is
                 ours so card/tile rounding reads from one place. -->
            <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
            <!-- Same 8 as a scalar, for Rectangle.RadiusX/Y (which take a double, not a CornerRadius)
                 so dotted group/drop outlines round to the card radius from one place. -->
            <x:Double x:Key="CardCornerRadiusValue">8</x:Double>

            <!-- Caps line length on wide monitors instead of stretching content edge-to-edge
                 (Fluent 2 layout). Pages centre their content within this. -->
            <x:Double x:Key="ContentMaxWidth">1120</x:Double>

            <!-- Top inset is 0 so each page's H1 title lines up with the top of the first nav-rail
                 item (both share the NavigationView's title-bar TopPadding). -->
            <Thickness x:Key="PagePadding">16,0,16,20</Thickness>
            <Thickness x:Key="SectionPadding">16</Thickness>
            <Thickness x:Key="SubtleCardPadding">12,10</Thickness>

            <!-- Devices page content insets. Padding/Margin need a Thickness, and the Spacing* tokens
                 are x:Double (binding one to a Thickness throws at load), so these centralise the page's
                 content margins as Thicknesses on the 4px Fluent grid: 16 = the page side/top margin (as
                 in PagePadding). The scroll region keeps its scrollbar at the window edge, so its padding
                 is sides-only and the bottom breathing room lives on the list itself
                 (DevicesListBottomMargin) - that way cards scroll flush to the bottom edge and only the
                 last one clears it. -->
            <Thickness x:Key="DevicesHeaderPadding">16,16,16,0</Thickness>
            <Thickness x:Key="DevicesScrollPadding">16,0,16,0</Thickness>
            <Thickness x:Key="DevicesListBottomMargin">0,0,0,28</Thickness>
            <Thickness x:Key="DevicesPlaceholderMargin">16,0,16,20</Thickness>

            <Style x:Key="PageHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource TitleTextBlockStyle}">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>

            <Style x:Key="PageSubheaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}" />

            <Style x:Key="MutedCaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- Mica fills the whole window uniformly, like Windows Settings. NavigationView otherwise
                 paints a lighter layer (LayerFillColorDefault) behind its content region, so the content
                 area reads lighter than the Mica pane. Transparent = one continuous Mica backdrop behind
                 pane + content. QuickControlsWindow has no NavigationView (its root is already
                 transparent), so this brings the two windows into visual agreement. -->
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            <!-- Drop the NavigationView content-region border so there's no hairline between the title
                 bar and the content - one continuous Mica surface, like Settings. -->
            <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>

            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource SectionCardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SectionCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
                <Setter Property="Padding" Value="{StaticResource SectionPadding}" />
            </Style>

            <SolidColorBrush x:Key="GroupTitleBandBackgroundBrush" Color="Transparent" />

            <Style x:Key="SubtleCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
                <Setter Property="Padding" Value="{StaticResource SubtleCardPadding}" />
            </Style>

            <Style x:Key="EmphasizedSubtleCardStyle" TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
                <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                <Setter Property="Padding" Value="14,12" />
            </Style>

            <Style x:Key="ChipBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
                <Setter Property="Padding" Value="8,2" />
            </Style>

            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCriticalBrush}" />
                <Setter Property="Padding" Value="11,5,11,6" />
            </Style>

            <Style x:Key="GhostIconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Padding" Value="6" />
                <Setter Property="MinWidth" Value="32" />
            </Style>

            <!-- Subtle, full-width clickable chip used for rule summaries on the Devices page.
                 No border - background colour alone carries the chip. -->
            <Style x:Key="SubtleRuleChipButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
                <Setter Property="Padding" Value="{StaticResource SubtleCardPadding}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
