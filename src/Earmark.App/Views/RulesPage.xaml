<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Earmark.App.Views.RulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Earmark.App.ViewModels"
    xmlns:models="using:Earmark.Core.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="Rules" Style="{StaticResource PageHeaderTextStyle}" />
                <TextBlock Style="{StaticResource PageSubheaderTextStyle}"
                           Text="Drag to reorder. Topmost matching rule wins. Click to edit. Dimmed rules are off, shadowed, or have unmet conditions." />
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.AddCommand}"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="Add rule" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Command="{x:Bind ViewModel.ReapplyCommand}"
                    VerticalAlignment="Center"
                    ToolTipService.ToolTip="Force re-apply of all rules">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Reapply" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Empty state -->
        <Border Grid.Row="1"
                Style="{StaticResource SectionCardStyle}"
                Padding="32"
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <FontIcon Glyph="&#xE8FD;" FontSize="40"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No rules yet"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Style="{StaticResource MutedCaptionTextStyle}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="Create a rule to route an application to a specific output or input device, or to pin the system default device." />
                <Button Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.AddCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="Add your first rule" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <ListView Grid.Row="1"
                  x:Name="RulesList"
                  ItemsSource="{x:Bind ViewModel.Items}"
                  SelectionMode="None"
                  CanReorderItems="True"
                  CanDragItems="True"
                  AllowDrop="True"
                  Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,4" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:RuleRow">
                    <Border Style="{StaticResource SectionCardStyle}"
                            Opacity="{x:Bind CardOpacity, Mode=OneWay}">
                        <StackPanel Spacing="14">

                            <!-- Header -->
                            <Grid ColumnSpacing="12"
                                  Background="Transparent"
                                  Tapped="OnHeaderTapped">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE700;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                          VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="1"
                                              IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                              OffContent="" OnContent=""
                                              MinWidth="0" Width="44"
                                              VerticalAlignment="Center" />
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <FontIcon Glyph="&#xE7BA;" FontSize="13"
                                                  Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                  VerticalAlignment="Center"
                                                  Visibility="{x:Bind HasWarning, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  ToolTipService.ToolTip="{x:Bind Warning, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind StatusMessage, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Visibility="{x:Bind HasStatusMessage, Mode=OneWay}" />
                                        <TextBlock Text="{x:Bind MatchSummary, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   Visibility="{x:Bind HasMatchSummary, Mode=OneWay}" />
                                    </StackPanel>
                                </StackPanel>
                                <FontIcon Grid.Column="3"
                                          Glyph="&#xE70D;" FontSize="12"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />
                            </Grid>

                            <!-- Inline editor -->
                            <StackPanel Spacing="16" Visibility="{x:Bind IsExpanded, Mode=OneWay}">

                                <TextBox Header="Name"
                                         Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <!-- Conditions -->
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="Conditions" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Style="{StaticResource MutedCaptionTextStyle}"
                                                       Text="All conditions must be true for the rule to take effect. Leave empty to always run." />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{x:Bind AddConditionCommand}"
                                                VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                                <TextBlock Text="Add condition" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <ItemsControl ItemsSource="{x:Bind Conditions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ConditionRow">
                                                <Border Style="{StaticResource SubtleCardStyle}" Margin="0,4,0,0">
                                                    <Grid ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="170" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <FontIcon Grid.Column="0"
                                                                  Glyph="{x:Bind IsSatisfied, Mode=OneWay, Converter={StaticResource SatisfiedGlyphConverter}}"
                                                                  Foreground="{x:Bind IsSatisfied, Mode=OneWay, Converter={StaticResource SatisfiedBrushConverter}}"
                                                                  FontSize="14"
                                                                  VerticalAlignment="Center"
                                                                  ToolTipService.ToolTip="{x:Bind IsSatisfied, Mode=OneWay, Converter={StaticResource SatisfiedTooltipConverter}}" />

                                                        <ComboBox Grid.Column="1"
                                                                  ItemsSource="{x:Bind AvailableTypeOptions}"
                                                                  SelectedItem="{x:Bind SelectedTypeOption, Mode=OneWay}"
                                                                  SelectionChanged="OnConditionTypeChanged"
                                                                  HorizontalAlignment="Stretch" />

                                                        <ComboBox Grid.Column="2"
                                                                  ItemsSource="{x:Bind AvailableFlowOptions}"
                                                                  SelectedItem="{x:Bind SelectedFlowOption, Mode=OneWay}"
                                                                  SelectionChanged="OnConditionFlowChanged"
                                                                  HorizontalAlignment="Stretch" />

                                                        <TextBox Grid.Column="3"
                                                                 PlaceholderText=".*Headphones.*"
                                                                 Text="{x:Bind DevicePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                        <Button Grid.Column="4"
                                                                Style="{StaticResource GhostIconButtonStyle}"
                                                                Click="OnRemoveConditionClicked"
                                                                Tag="{x:Bind}"
                                                                ToolTipService.ToolTip="Remove condition">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="Actions" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Style="{StaticResource MutedCaptionTextStyle}"
                                                       Text="Each action runs in order. Topmost wins for the same target." />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Command="{x:Bind AddActionCommand}"
                                                VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                                <TextBlock Text="Add action" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <ItemsControl ItemsSource="{x:Bind Actions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ActionRow">
                                                <Border Style="{StaticResource EmphasizedSubtleCardStyle}" Margin="0,4,0,0">
                                                    <StackPanel Spacing="10">
                                                        <Grid ColumnSpacing="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="240" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <ComboBox Grid.Column="0"
                                                                      Header="Action"
                                                                      ItemsSource="{x:Bind AvailableTypeOptions}"
                                                                      SelectedItem="{x:Bind SelectedTypeOption, Mode=OneWay}"
                                                                      SelectionChanged="OnActionTypeChanged"
                                                                      HorizontalAlignment="Stretch" />

                                                            <Button Grid.Column="2"
                                                                    Style="{StaticResource GhostIconButtonStyle}"
                                                                    Click="OnRemoveActionClicked"
                                                                    Tag="{x:Bind}"
                                                                    VerticalAlignment="Bottom"
                                                                    ToolTipService.ToolTip="Remove action">
                                                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                            </Button>
                                                        </Grid>

                                                        <AutoSuggestBox PlaceholderText="Headphone Mix"
                                                                        Text="{x:Bind MixPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        TextChanged="OnMixPatternTextChanged"
                                                                        SuggestionChosen="OnMixSuggestionChosen"
                                                                        GotFocus="OnMixPatternGotFocus"
                                                                        Visibility="{x:Bind IsWaveLinkAction, Mode=OneWay}">
                                                            <AutoSuggestBox.Header>
                                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                    <TextBlock Text="Mix pattern (regex)" VerticalAlignment="Center" />
                                                                    <Border Style="{StaticResource ChipBorderStyle}"
                                                                            Visibility="{x:Bind HasMixMatch, Mode=OneWay}">
                                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                                            <FontIcon Glyph="&#xE9D5;" FontSize="11"
                                                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                      VerticalAlignment="Center" />
                                                                            <TextBlock Text="{x:Bind MixMatchSummary, Mode=OneWay}"
                                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                                       VerticalAlignment="Center" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                            </AutoSuggestBox.Header>
                                                        </AutoSuggestBox>

                                                        <TextBox PlaceholderText=".*chrome.*"
                                                                 Text="{x:Bind AppPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Visibility="{x:Bind RequiresAppPattern, Mode=OneWay}">
                                                            <TextBox.Header>
                                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                    <TextBlock Text="App pattern (regex)" VerticalAlignment="Center" />
                                                                    <Border Style="{StaticResource ChipBorderStyle}"
                                                                            Visibility="{x:Bind HasAppMatches, Mode=OneWay}"
                                                                            ToolTipService.ToolTip="{x:Bind AppMatchNames, Mode=OneWay}">
                                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                                            <FontIcon Glyph="&#xE946;" FontSize="11"
                                                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                      VerticalAlignment="Center" />
                                                                            <TextBlock Text="{x:Bind AppMatchSummary, Mode=OneWay}"
                                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                                       VerticalAlignment="Center" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                            </TextBox.Header>
                                                        </TextBox>

                                                        <AutoSuggestBox PlaceholderText=".*Headphones.*"
                                                                        Text="{x:Bind DevicePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        TextChanged="OnDevicePatternTextChanged"
                                                                        SuggestionChosen="OnDeviceSuggestionChosen"
                                                                        GotFocus="OnDevicePatternGotFocus">
                                                            <AutoSuggestBox.Header>
                                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                    <TextBlock Text="Device pattern (regex)" VerticalAlignment="Center" />
                                                                    <Border Style="{StaticResource ChipBorderStyle}"
                                                                            Visibility="{x:Bind HasDeviceMatch, Mode=OneWay}">
                                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                                            <FontIcon Glyph="&#xE7F5;" FontSize="11"
                                                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                      VerticalAlignment="Center" />
                                                                            <TextBlock Text="{x:Bind DeviceMatchSummary, Mode=OneWay}"
                                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                                       VerticalAlignment="Center" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                            </AutoSuggestBox.Header>
                                                        </AutoSuggestBox>

                                                        <Slider Header="Volume"
                                                                Minimum="0" Maximum="100" StepFrequency="1"
                                                                TickFrequency="10" TickPlacement="BottomRight"
                                                                Value="{x:Bind Volume, Mode=TwoWay, Converter={StaticResource VolumeFloatToPercentConverter}}"
                                                                Visibility="{x:Bind RequiresVolumeSlider, Mode=OneWay}" />

                                                        <StackPanel Orientation="Horizontal" Spacing="24"
                                                                    Visibility="{x:Bind IsDefaultAction, Mode=OneWay}">
                                                            <ToggleSwitch Header="Default device"
                                                                          OffContent="Off" OnContent="On"
                                                                          IsOn="{x:Bind SetsDefault, Mode=TwoWay}" />
                                                            <ToggleSwitch Header="Communications device"
                                                                          OffContent="Off" OnContent="On"
                                                                          IsOn="{x:Bind SetsCommunications, Mode=TwoWay}" />
                                                        </StackPanel>

                                                        <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                                                BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Padding="10,6"
                                                                Visibility="{x:Bind HasDiagnostic, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon Glyph="&#xE7BA;" FontSize="13"
                                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                                          VerticalAlignment="Center" />
                                                                <TextBlock Text="{x:Bind Diagnostic, Mode=OneWay}"
                                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                                           VerticalAlignment="Center"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Footer -->
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource DangerButtonStyle}"
                                            Click="OnDeleteRuleClicked"
                                            Tag="{x:Bind}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                            <TextBlock Text="Delete rule" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
