<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Earmark.App.Views.RulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Earmark.App.ViewModels"
    xmlns:models="using:Earmark.Core.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,16">
            <TextBlock Text="Rules" Style="{StaticResource PageHeaderTextStyle}" />
            <Button Content="Add rule" Command="{x:Bind ViewModel.AddCommand}" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center" />
            <Button Content="Reapply now" Command="{x:Bind ViewModel.ReapplyCommand}" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="Drag rules to reorder. Topmost matching rule wins. Click a rule to edit it inline."
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Opacity="0.6"
                   Margin="0,0,0,16" />

        <ListView Grid.Row="2"
                  x:Name="RulesList"
                  ItemsSource="{x:Bind ViewModel.Items}"
                  SelectionMode="None"
                  CanReorderItems="True"
                  CanDragItems="True"
                  AllowDrop="True">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:RuleRow">
                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,4">
                        <StackPanel Spacing="12">

                            <!-- Header (always visible) -->
                            <Grid ColumnSpacing="10" Tapped="OnHeaderTapped">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0" Glyph="&#xE700;" FontSize="14" Opacity="0.4" VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="1"
                                              IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                              OffContent="" OnContent=""
                                              MinWidth="0" Width="44"
                                              VerticalAlignment="Center" />
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{x:Bind DeviceMatchSummary, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.65"
                                                   Visibility="{x:Bind HasDeviceMatch, Mode=OneWay}" />
                                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10" Padding="8,2"
                                                ToolTipService.ToolTip="{x:Bind AppMatchNames, Mode=OneWay}"
                                                Visibility="{x:Bind HasAppMatches, Mode=OneWay}"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE946;" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                                                <TextBlock Text="{x:Bind AppMatchSummary, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="3" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind TypeLabel, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" />
                                </Border>
                                <FontIcon Grid.Column="4" Glyph="&#xE70D;" FontSize="12" Opacity="0.6" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Inline editor -->
                            <StackPanel Spacing="10" Visibility="{x:Bind IsExpanded, Mode=OneWay}">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Header="Name" Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="1" Header="Rule type"
                                              ItemsSource="{x:Bind AvailableTypeOptions}"
                                              SelectedItem="{x:Bind SelectedTypeOption, Mode=OneWay}"
                                              SelectionChanged="OnTypeChanged"
                                              MinWidth="220" />
                                </Grid>

                                <TextBox Header="App pattern (regex)"
                                         PlaceholderText=".*steamapps.*"
                                         Text="{x:Bind AppPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Visibility="{x:Bind RequiresAppPattern, Mode=OneWay}" />

                                <TextBox Header="Device pattern (regex)"
                                         PlaceholderText=".*Headphones.*"
                                         Text="{x:Bind DevicePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel Orientation="Horizontal" Spacing="24"
                                            Visibility="{x:Bind IsDefaultRule, Mode=OneWay}">
                                    <ToggleSwitch Header="Default device"
                                                  OffContent="Off" OnContent="On"
                                                  IsOn="{x:Bind SetsDefault, Mode=TwoWay}" />
                                    <ToggleSwitch Header="Communications device"
                                                  OffContent="Off" OnContent="On"
                                                  IsOn="{x:Bind SetsCommunications, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Content="Delete"
                                            Background="Transparent"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            Click="OnDeleteClicked"
                                            Tag="{x:Bind}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
