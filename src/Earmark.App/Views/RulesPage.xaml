<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Earmark.App.Views.RulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Earmark.App.ViewModels"
    xmlns:models="using:Earmark.Core.Models"
    xmlns:controls="using:Earmark.App.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <!-- One condition-editor template shared by the conditions list. A Subtle card with a drag
             handle + satisfied indicator, the consolidated Device / Default device / Application
             picker, a present/missing (running/not) polarity toggle, the flow + pattern, and
             duplicate / remove. -->
        <DataTemplate x:Key="ConditionRowTemplate" x:DataType="vm:ConditionRow">
            <Border Style="{StaticResource SubtleCardStyle}" Margin="0,4,0,0">
                <StackPanel Spacing="{StaticResource SpacingSmall}">
                    <Grid ColumnSpacing="{StaticResource SpacingSmall}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0"
                                  Glyph="&#xE700;" FontSize="14"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  VerticalAlignment="Center"
                                  ToolTipService.ToolTip="Drag to reorder, or onto another rule" />

                        <FontIcon Grid.Column="1"
                                  Glyph="{x:Bind IsSatisfied, Mode=OneWay, Converter={StaticResource SatisfiedGlyphConverter}}"
                                  Foreground="{x:Bind IsSatisfied, Mode=OneWay, Converter={StaticResource SatisfiedBrushConverter}}"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  ToolTipService.ToolTip="{x:Bind IsSatisfied, Mode=OneWay, Converter={StaticResource SatisfiedTooltipConverter}}" />

                        <!-- Kind + polarity + flow read as one line ("Device · Present · Output"); the
                             combos / toggle are self-labeling, so no field headers. -->
                        <ComboBox Grid.Column="2"
                                  MinWidth="150"
                                  ItemsSource="{x:Bind AvailableKindOptions}"
                                  SelectedItem="{x:Bind SelectedKindOption, Mode=OneWay}"
                                  SelectionChanged="OnConditionKindChanged"
                                  VerticalAlignment="Center" />

                        <ToggleSwitch Grid.Column="3"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      IsOn="{x:Bind IsPositive, Mode=TwoWay}"
                                      OnContent="{x:Bind PositiveLabel, Mode=OneWay}"
                                      OffContent="{x:Bind NegativeLabel, Mode=OneWay}" />

                        <ComboBox Grid.Column="4"
                                  MinWidth="104"
                                  ItemsSource="{x:Bind AvailableFlowOptions}"
                                  SelectedItem="{x:Bind SelectedFlowOption, Mode=OneWay}"
                                  SelectionChanged="OnConditionFlowChanged"
                                  VerticalAlignment="Center"
                                  ToolTipService.ToolTip="Which flow to match: any, output (render), or input (capture)"
                                  Visibility="{x:Bind IsDeviceCondition, Mode=OneWay}" />

                        <Button Grid.Column="6"
                                Style="{StaticResource GhostIconButtonStyle}"
                                Click="OnDuplicateConditionClicked"
                                Tag="{x:Bind}"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="Duplicate condition">
                            <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                        </Button>

                        <Button Grid.Column="7"
                                Style="{StaticResource GhostIconButtonStyle}"
                                Click="OnRemoveConditionClicked"
                                Tag="{x:Bind}"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="Remove condition">
                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                        </Button>
                    </Grid>

                    <Grid ColumnSpacing="{StaticResource SpacingSmall}" Visibility="{x:Bind IsDeviceCondition, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <AutoSuggestBox Grid.Column="0"
                                        PlaceholderText=".*Headphones.*"
                                        Text="{x:Bind DevicePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="OnDevicePatternTextChanged"
                                        SuggestionChosen="OnDeviceSuggestionChosen"
                                        GotFocus="OnDevicePatternGotFocus">
                            <AutoSuggestBox.Header>
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center">
                                    <TextBlock Text="Device pattern" VerticalAlignment="Center" />
                                    <Border Style="{StaticResource ChipBorderStyle}"
                                            Visibility="{x:Bind HasDeviceMatch, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE7F5;" FontSize="11"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind DeviceMatchSummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </AutoSuggestBox.Header>
                        </AutoSuggestBox>
                        <ComboBox Grid.Column="1" Header="Match" MinWidth="112" VerticalAlignment="Bottom"
                                  ItemsSource="{x:Bind DeviceModeOptions}"
                                  SelectedItem="{x:Bind SelectedDeviceMode, Mode=OneWay}"
                                  SelectionChanged="OnDeviceModeChanged"
                                  ToolTipService.ToolTip="How the device pattern is matched: Regex, Wildcard (* ?), or pick an exact Device" />
                    </Grid>

                    <Grid ColumnSpacing="{StaticResource SpacingSmall}" Visibility="{x:Bind IsApplicationCondition, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <AutoSuggestBox Grid.Column="0"
                                        PlaceholderText=".*discord.*"
                                        Text="{x:Bind AppPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="OnAppPatternTextChanged"
                                        SuggestionChosen="OnAppSuggestionChosen"
                                        GotFocus="OnAppPatternGotFocus">
                            <AutoSuggestBox.Header>
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center">
                                    <TextBlock Text="App pattern" VerticalAlignment="Center" />
                                    <Border Style="{StaticResource ChipBorderStyle}"
                                            Visibility="{x:Bind HasAppMatches, Mode=OneWay}"
                                            ToolTipService.ToolTip="{x:Bind AppMatchNames, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE946;" FontSize="11"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind AppMatchSummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </AutoSuggestBox.Header>
                        </AutoSuggestBox>
                        <ComboBox Grid.Column="1" Header="Match" MinWidth="112" VerticalAlignment="Bottom"
                                  ItemsSource="{x:Bind AppModeOptions}"
                                  SelectedItem="{x:Bind SelectedAppMode, Mode=OneWay}"
                                  SelectionChanged="OnAppModeChanged"
                                  ToolTipService.ToolTip="How the app pattern is matched: Regex, Wildcard (* ?), or pick an exact App" />
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- One action-editor template shared by the main Actions list and the "Otherwise"
             (else) list. The remove / duplicate buttons route to the right list in code-behind
             based on which collection the row belongs to. -->
        <DataTemplate x:Key="ActionRowTemplate" x:DataType="vm:ActionRow">
            <Border Style="{StaticResource EmphasizedSubtleCardStyle}" Margin="0,4,0,0">
                <StackPanel Spacing="{StaticResource SpacingSmall}">
                    <!-- Verb line: the action kind, its self-labeling mode control (one shows by
                         kind: Output/Input, mix membership, or Mute/Unmute), and the Pin toggle read
                         as one row of intent - the controls carry the meaning, so no field headers.
                         Drag handle on the left, row actions on the right. -->
                    <Grid ColumnSpacing="{StaticResource SpacingSmall}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0"
                                  Glyph="&#xE700;" FontSize="14"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  VerticalAlignment="Center"
                                  ToolTipService.ToolTip="Drag to reorder, between Actions / Otherwise, or onto another rule" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}" VerticalAlignment="Center">
                            <ComboBox MinWidth="190"
                                      ItemsSource="{x:Bind AvailableKindOptions}"
                                      SelectedItem="{x:Bind SelectedKindOption, Mode=OneWay}"
                                      SelectionChanged="OnActionKindChanged"
                                      VerticalAlignment="Center" />

                            <ToggleSwitch MinWidth="0" VerticalAlignment="Center"
                                          OffContent="Output" OnContent="Input"
                                          IsOn="{x:Bind IsInput, Mode=TwoWay}"
                                          Visibility="{x:Bind ShowDirection, Mode=OneWay}" />

                            <ComboBox MinWidth="220" VerticalAlignment="Center"
                                      ItemsSource="{x:Bind AvailableMembershipOptions}"
                                      SelectedItem="{x:Bind SelectedMembershipOption, Mode=OneWay}"
                                      SelectionChanged="OnActionMembershipChanged"
                                      Visibility="{x:Bind ShowMembership, Mode=OneWay}" />

                            <ToggleSwitch MinWidth="0" VerticalAlignment="Center"
                                          OffContent="Unmute" OnContent="Mute"
                                          IsOn="{x:Bind Muted, Mode=TwoWay}"
                                          Visibility="{x:Bind ShowMuteToggle, Mode=OneWay}" />

                            <!-- Pin vs one-shot. Pinned reverts external drift; one-shot applies once
                                 when the rule's branch activates, then leaves the device editable. -->
                            <ToggleSwitch MinWidth="0" VerticalAlignment="Center"
                                          OffContent="One-shot" OnContent="Pinned"
                                          IsOn="{x:Bind Pinned, Mode=TwoWay}"
                                          ToolTipService.ToolTip="Pinned reverts external changes back to this setting. One-shot applies it once when the rule's conditions are first met, then leaves it free to change." />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="{StaticResource SpacingXSmall}" VerticalAlignment="Center">
                            <!-- Shadowed: an earlier, higher-priority rule already claims this action's
                                 target, so it won't run. Same caution glyph as the rule-level warning. -->
                            <FontIcon Glyph="&#xE7BA;" FontSize="14"
                                      Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                      VerticalAlignment="Center"
                                      Visibility="{x:Bind IsShadowed, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      ToolTipService.ToolTip="Superseded by a higher-priority rule - this action won't run." />

                            <Button Style="{StaticResource GhostIconButtonStyle}"
                                    Click="OnDuplicateActionClicked"
                                    Tag="{x:Bind}"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Duplicate action">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                            </Button>

                            <Button Style="{StaticResource GhostIconButtonStyle}"
                                    Click="OnRemoveActionClicked"
                                    Tag="{x:Bind}"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Remove action">
                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="{StaticResource SpacingSmall}" Visibility="{x:Bind IsWaveLinkAction, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <AutoSuggestBox Grid.Column="0"
                                        PlaceholderText="Headphone Mix"
                                        Text="{x:Bind MixPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="OnMixPatternTextChanged"
                                        SuggestionChosen="OnMixSuggestionChosen"
                                        GotFocus="OnMixPatternGotFocus">
                            <AutoSuggestBox.Header>
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center">
                                    <TextBlock Text="Mix pattern" VerticalAlignment="Center" />
                                    <Border Style="{StaticResource ChipBorderStyle}"
                                            Visibility="{x:Bind HasMixMatch, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE9D5;" FontSize="11"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind MixMatchSummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </AutoSuggestBox.Header>
                        </AutoSuggestBox>
                        <ComboBox Grid.Column="1" Header="Match" MinWidth="112" VerticalAlignment="Bottom"
                                  ItemsSource="{x:Bind MixModeOptions}"
                                  SelectedItem="{x:Bind SelectedMixMode, Mode=OneWay}"
                                  SelectionChanged="OnMixModeChanged"
                                  ToolTipService.ToolTip="How the mix pattern is matched: Regex, Wildcard (* ?), or pick an exact Mix" />
                    </Grid>

                    <Grid ColumnSpacing="{StaticResource SpacingSmall}" Visibility="{x:Bind RequiresAppPattern, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <AutoSuggestBox Grid.Column="0"
                                        PlaceholderText=".*chrome.*"
                                        Text="{x:Bind AppPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="OnAppPatternTextChanged"
                                        SuggestionChosen="OnAppSuggestionChosen"
                                        GotFocus="OnAppPatternGotFocus">
                            <AutoSuggestBox.Header>
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center">
                                    <TextBlock Text="App pattern" VerticalAlignment="Center" />
                                    <Border Style="{StaticResource ChipBorderStyle}"
                                            Visibility="{x:Bind HasAppMatches, Mode=OneWay}"
                                            ToolTipService.ToolTip="{x:Bind AppMatchNames, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE946;" FontSize="11"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind AppMatchSummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </AutoSuggestBox.Header>
                        </AutoSuggestBox>
                        <ComboBox Grid.Column="1" Header="Match" MinWidth="112" VerticalAlignment="Bottom"
                                  ItemsSource="{x:Bind AppModeOptions}"
                                  SelectedItem="{x:Bind SelectedAppMode, Mode=OneWay}"
                                  SelectionChanged="OnAppModeChanged"
                                  ToolTipService.ToolTip="How the app pattern is matched: Regex, Wildcard (* ?), or pick an exact App" />
                    </Grid>

                    <Grid ColumnSpacing="{StaticResource SpacingSmall}" Visibility="{x:Bind RequiresDevicePattern, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <AutoSuggestBox Grid.Column="0"
                                        PlaceholderText=".*Headphones.*"
                                        Text="{x:Bind DevicePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="OnDevicePatternTextChanged"
                                        SuggestionChosen="OnDeviceSuggestionChosen"
                                        GotFocus="OnDevicePatternGotFocus">
                            <AutoSuggestBox.Header>
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center">
                                    <TextBlock Text="Device pattern" VerticalAlignment="Center" />
                                    <Border Style="{StaticResource ChipBorderStyle}"
                                            Visibility="{x:Bind HasDeviceMatch, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE7F5;" FontSize="11"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind DeviceMatchSummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </AutoSuggestBox.Header>
                        </AutoSuggestBox>
                        <ComboBox Grid.Column="1" Header="Match" MinWidth="112" VerticalAlignment="Bottom"
                                  ItemsSource="{x:Bind DeviceModeOptions}"
                                  SelectedItem="{x:Bind SelectedDeviceMode, Mode=OneWay}"
                                  SelectionChanged="OnDeviceModeChanged"
                                  ToolTipService.ToolTip="How the device pattern is matched: Regex, Wildcard (* ?), or pick an exact Device" />
                    </Grid>

                    <TextBox Header="New name"
                             PlaceholderText="Living Room Speakers"
                             Text="{x:Bind NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{x:Bind RequiresNewName, Mode=OneWay}" />

                    <Slider Header="Volume"
                            Minimum="0" Maximum="100" StepFrequency="1"
                            TickFrequency="10" TickPlacement="BottomRight"
                            Value="{x:Bind Volume, Mode=TwoWay, Converter={StaticResource VolumeFloatToPercentConverter}}"
                            Visibility="{x:Bind RequiresVolumeSlider, Mode=OneWay}" />

                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingXLarge}"
                                Visibility="{x:Bind IsDefaultAction, Mode=OneWay}">
                        <ToggleSwitch Header="Default device"
                                      OffContent="Off" OnContent="On"
                                      IsOn="{x:Bind SetsDefault, Mode=TwoWay}" />
                        <ToggleSwitch Header="Communications device"
                                      OffContent="Off" OnContent="On"
                                      IsOn="{x:Bind SetsCommunications, Mode=TwoWay}" />
                    </StackPanel>

                    <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                            BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                            BorderThickness="1"
                            CornerRadius="{ThemeResource ControlCornerRadius}"
                            Padding="8,4"
                            Visibility="{x:Bind HasDiagnostic, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                            <FontIcon Glyph="&#xE7BA;" FontSize="13"
                                      Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind Diagnostic, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="{StaticResource SpacingLarge}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Grid Grid.Row="0" ColumnSpacing="{StaticResource SpacingMedium}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center"
                        Background="Transparent"
                        AllowDrop="True"
                        DragOver="OnRulesHeaderDragOver"
                        Drop="OnRulesHeaderDrop">
                <TextBlock Text="Rules" Style="{StaticResource PageHeaderTextStyle}" />
                <FontIcon Glyph="&#xE946;" FontSize="14"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          VerticalAlignment="Center"
                          ToolTipService.ToolTip="Drag to reorder. Topmost matching rule wins. Drag onto this title to move to the top. Click to edit." />
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.AddCommand}"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="Add rule" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Command="{x:Bind ViewModel.ReapplyCommand}"
                    VerticalAlignment="Center"
                    ToolTipService.ToolTip="Force re-apply of all rules">
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Reapply" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Empty state -->
        <Border Grid.Row="1"
                Style="{StaticResource SectionCardStyle}"
                Padding="32"
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Spacing="{StaticResource SpacingMedium}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <FontIcon Glyph="&#xE8FD;" FontSize="40"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No rules yet"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Style="{StaticResource MutedCaptionTextStyle}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="Create a rule to route an application to a specific output or input device, or to pin the system default device." />
                <Button Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.AddCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="Add your first rule" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Negative right margin cancels the page's 28px right padding so the scroll bar lives
             in a gutter at the content edge; the matching right padding re-insets the cards so
             they still line up at 28px on both sides. Without this the overlay scroll bar sits
             on top of the chevron at the card's right edge. -->
        <ListView Grid.Row="1"
                  x:Name="RulesList"
                  Margin="0,0,-28,0"
                  Padding="0,0,28,0"
                  ItemsSource="{x:Bind ViewModel.Items}"
                  SelectionMode="None"
                  CanDragItems="True"
                  AllowDrop="True"
                  DragItemsStarting="OnRulesDragStarting"
                  DragItemsCompleted="OnRulesDragCompleted"
                  DragOver="OnRulesDragOver"
                  Drop="OnRulesDrop"
                  ContainerContentChanging="OnItemContainerChanging"
                  Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,4" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:RuleRow">
                    <!-- No card padding: the header ExpanderPill spans the full card so its
                         chevron can sit flush against the card's top/right/bottom edges. The
                         header content and editor pad themselves instead. The card stays opaque
                         (dimming is applied to the content below, not here) so the ListViewItem's
                         own hover/selection chrome can't show through a faded card. -->
                    <Border CornerRadius="{StaticResource CardCornerRadius}"
                            Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <!-- Right-click shortcuts that mirror the in-row toggle and Delete button. -->
                        <Border.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="{x:Bind EnabledToggleLabel, Mode=OneWay}"
                                                Command="{x:Bind ToggleEnabledCommand}" />
                                <MenuFlyoutItem Text="Duplicate rule"
                                                Click="OnDuplicateRuleClicked"
                                                Tag="{x:Bind}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8C8;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Delete rule"
                                                Click="OnDeleteRuleClicked"
                                                Tag="{x:Bind}">
                                    <!-- Critical red across rest/hover/press so the destructive
                                         action reads as destructive; the default template would
                                         otherwise swap the foreground to the neutral theme brush
                                         on pointer-over. -->
                                    <MenuFlyoutItem.Resources>
                                        <SolidColorBrush x:Key="MenuFlyoutItemForeground" Color="{ThemeResource SystemFillColorCritical}" />
                                        <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="{ThemeResource SystemFillColorCritical}" />
                                        <SolidColorBrush x:Key="MenuFlyoutItemForegroundPressed" Color="{ThemeResource SystemFillColorCritical}" />
                                    </MenuFlyoutItem.Resources>
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Border.ContextFlyout>
                        <!-- Dimming (disabled / shadowed / unmet conditions) fades the content,
                             not the card surface, so nothing shows through from behind. -->
                        <StackPanel Spacing="0" Opacity="{x:Bind CardOpacity, Mode=OneWay}">

                            <!-- Header as one full-width ExpanderPill: drag handle + enable
                                 toggle + rule summary on the left, chevron as a flush right-edge
                                 strip. Tapping the pill toggles the editor. The dragged row is
                                 collapsed for the drag (DragItemsStarting) so you move a compact
                                 block, then restored on completion. -->
                            <controls:ExpanderPill PillBackground="Transparent"
                                                   ChevronCornerRadius="0,8,8,0"
                                                   PlainChevronWhenExpanded="True"
                                                   IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}">
                                <controls:ExpanderPill.PillContent>
                                    <Grid ColumnSpacing="{StaticResource SpacingMedium}" Padding="16,16,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE700;" FontSize="14"
                                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                  VerticalAlignment="Center"
                                                  ToolTipService.ToolTip="Drag to reorder" />
                                        <ToggleSwitch Grid.Column="1"
                                                      IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                                      OffContent="" OnContent=""
                                                      MinWidth="0" Width="44"
                                                      VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="2" Spacing="{StaticResource SpacingXXSmall}" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                                <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                <FontIcon Glyph="&#xE7BA;" FontSize="13"
                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                          VerticalAlignment="Center"
                                                          Visibility="{x:Bind HasWarning, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                          ToolTipService.ToolTip="{x:Bind Warning, Mode=OneWay}" />
                                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="{ThemeResource ControlCornerRadius}"
                                                        Padding="6,1" VerticalAlignment="Center"
                                                        Visibility="{x:Bind IsDirty, Mode=OneWay}"
                                                        ToolTipService.ToolTip="This rule has unsaved edits. They aren't applied until you click Save.">
                                                    <TextBlock Text="Unsaved"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                                <TextBlock Text="{x:Bind StatusMessage, Mode=OneWay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Visibility="{x:Bind HasStatusMessage, Mode=OneWay}" />
                                                <TextBlock Text="{x:Bind MatchSummary, Mode=OneWay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                           Visibility="{x:Bind HasMatchSummary, Mode=OneWay}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </controls:ExpanderPill.PillContent>
                            </controls:ExpanderPill>

                            <!-- Inline editor. Instant Visibility (not an animated accordion) so
                                 the dragged row collapses immediately for a clean reorder. Pads
                                 itself since the card carries no padding (see header note). -->
                            <StackPanel Spacing="{StaticResource SpacingLarge}" Padding="16,0,16,16"
                                        Visibility="{x:Bind IsExpanded, Mode=OneWay}">

                                <TextBox Header="Name"
                                         Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <!-- Conditions -->
                                <StackPanel Spacing="{StaticResource SpacingSmall}">
                                    <!-- The title is a drop target that lands a dragged condition at
                                         the top of the list (index 0) - the only target when the rule
                                         has no conditions yet, and a "drop at the top" zone otherwise. -->
                                    <Grid Background="Transparent"
                                          AllowDrop="True" Tag="Condition"
                                          DragOver="OnSectionHeaderDragOver" Drop="OnSectionHeaderDrop">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center">
                                            <TextBlock Text="Conditions" Style="{StaticResource SectionTitleTextStyle}" VerticalAlignment="Center" />
                                            <FontIcon Glyph="&#xE946;" FontSize="13"
                                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                      VerticalAlignment="Center"
                                                      ToolTipService.ToolTip="All conditions must be true for the rule to take effect. Leave empty to always run." />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{x:Bind AddConditionCommand}"
                                                VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                                <TextBlock Text="Add condition" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <ListView ItemsSource="{x:Bind Conditions}"
                                              ItemTemplate="{StaticResource ConditionRowTemplate}"
                                              SelectionMode="None"
                                              CanDragItems="True"
                                              AllowDrop="True"
                                              DragItemsStarting="OnConditionDragStarting"
                                              DragItemsCompleted="OnItemDragCompleted"
                                              DragOver="OnConditionDragOver"
                                              Drop="OnConditionDrop"
                                              ContainerContentChanging="OnItemContainerChanging"
                                              ScrollViewer.VerticalScrollMode="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ListView.ItemsPanel>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="MinHeight" Value="0" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>

                                    <!-- Empty-state drop zone: also the index-0 target so a condition
                                         can be dragged into a rule that has none yet. -->
                                    <Grid Visibility="{x:Bind HasNoConditions, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          Background="Transparent" Margin="0,4,0,0"
                                          AllowDrop="True" Tag="Condition"
                                          DragOver="OnSectionHeaderDragOver" Drop="OnSectionHeaderDrop">
                                        <Rectangle RadiusX="4" RadiusY="4"
                                                   Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
                                                   StrokeThickness="1" StrokeDashArray="3,3"
                                                   IsHitTestVisible="False" />
                                        <TextBlock Text="No conditions - drag one here, or use Add condition."
                                                   Style="{StaticResource MutedCaptionTextStyle}"
                                                   HorizontalAlignment="Center" Margin="12,10"
                                                   TextWrapping="Wrap" TextAlignment="Center" />
                                    </Grid>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Spacing="{StaticResource SpacingSmall}">
                                    <Grid Background="Transparent"
                                          AllowDrop="True" Tag="Action"
                                          DragOver="OnSectionHeaderDragOver" Drop="OnSectionHeaderDrop">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center">
                                            <TextBlock Text="Actions" Style="{StaticResource SectionTitleTextStyle}" VerticalAlignment="Center" />
                                            <FontIcon Glyph="&#xE946;" FontSize="13"
                                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                      VerticalAlignment="Center"
                                                      ToolTipService.ToolTip="Each action runs in order. Topmost wins for the same target." />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Command="{x:Bind AddActionCommand}"
                                                VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                                <TextBlock Text="Add action" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <ListView Tag="Actions"
                                              ItemsSource="{x:Bind Actions}"
                                              ItemTemplate="{StaticResource ActionRowTemplate}"
                                              SelectionMode="None"
                                              CanDragItems="True"
                                              AllowDrop="True"
                                              DragItemsStarting="OnActionDragStarting"
                                              DragItemsCompleted="OnItemDragCompleted"
                                              DragOver="OnActionDragOver"
                                              Drop="OnActionDrop"
                                              ContainerContentChanging="OnItemContainerChanging"
                                              ScrollViewer.VerticalScrollMode="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ListView.ItemsPanel>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="MinHeight" Value="0" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>

                                    <Grid Visibility="{x:Bind HasNoActions, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          Background="Transparent" Margin="0,4,0,0"
                                          AllowDrop="True" Tag="Action"
                                          DragOver="OnSectionHeaderDragOver" Drop="OnSectionHeaderDrop">
                                        <Rectangle RadiusX="4" RadiusY="4"
                                                   Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
                                                   StrokeThickness="1" StrokeDashArray="3,3"
                                                   IsHitTestVisible="False" />
                                        <TextBlock Text="No actions - drag one here, or use Add action."
                                                   Style="{StaticResource MutedCaptionTextStyle}"
                                                   HorizontalAlignment="Center" Margin="12,10"
                                                   TextWrapping="Wrap" TextAlignment="Center" />
                                    </Grid>
                                </StackPanel>

                                <!-- Otherwise (else) branch: actions that run when the rule's
                                     conditions are NOT met. Only shown when the rule has
                                     conditions. Reuses the shared ActionRowTemplate. -->
                                <StackPanel Spacing="{StaticResource SpacingSmall}"
                                            Visibility="{x:Bind ShowElse, Mode=OneWay}">
                                    <Grid Background="Transparent"
                                          AllowDrop="True" Tag="Action"
                                          DragOver="OnSectionHeaderDragOver" Drop="OnSectionHeaderDrop">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center">
                                            <TextBlock Text="Otherwise" Style="{StaticResource SectionTitleTextStyle}" VerticalAlignment="Center" />
                                            <FontIcon Glyph="&#xE946;" FontSize="13"
                                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                      VerticalAlignment="Center"
                                                      ToolTipService.ToolTip="Run these instead when the conditions above are not met." />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{x:Bind AddElseActionCommand}"
                                                VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                                <TextBlock Text="Add action" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <ListView Tag="Else"
                                              ItemsSource="{x:Bind ElseActions}"
                                              ItemTemplate="{StaticResource ActionRowTemplate}"
                                              SelectionMode="None"
                                              CanDragItems="True"
                                              AllowDrop="True"
                                              DragItemsStarting="OnActionDragStarting"
                                              DragItemsCompleted="OnItemDragCompleted"
                                              DragOver="OnActionDragOver"
                                              Drop="OnActionDrop"
                                              ContainerContentChanging="OnItemContainerChanging"
                                              ScrollViewer.VerticalScrollMode="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ListView.ItemsPanel>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="MinHeight" Value="0" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>

                                    <Grid Visibility="{x:Bind HasNoElseActions, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          Background="Transparent" Margin="0,4,0,0"
                                          AllowDrop="True" Tag="Action"
                                          DragOver="OnSectionHeaderDragOver" Drop="OnSectionHeaderDrop">
                                        <Rectangle RadiusX="4" RadiusY="4"
                                                   Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
                                                   StrokeThickness="1" StrokeDashArray="3,3"
                                                   IsHitTestVisible="False" />
                                        <TextBlock Text="No 'otherwise' actions - drag one here, or use Add action."
                                                   Style="{StaticResource MutedCaptionTextStyle}"
                                                   HorizontalAlignment="Center" Margin="12,10"
                                                   TextWrapping="Wrap" TextAlignment="Center" />
                                    </Grid>
                                </StackPanel>

                                <!-- Footer: Save / Discard appear only when the row has unsaved
                                     edits. Nothing persists or applies until Save - a half-typed
                                     pattern can't fire mid-edit. -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                Spacing="{StaticResource SpacingSmall}"
                                                Visibility="{x:Bind IsDirty, Mode=OneWay}">
                                        <Button Style="{StaticResource AccentButtonStyle}"
                                                Command="{x:Bind SaveCommand}"
                                                IsEnabled="{x:Bind CanSave, Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE74E;" FontSize="12" />
                                                <TextBlock Text="Save" />
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{x:Bind RevertCommand}"
                                                ToolTipService.ToolTip="Discard unsaved edits">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE7A7;" FontSize="12" />
                                                <TextBlock Text="Discard" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                        <Button Click="OnDuplicateRuleClicked"
                                                Tag="{x:Bind}"
                                                ToolTipService.ToolTip="Duplicate this rule below">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                                <TextBlock Text="Duplicate rule" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource DangerButtonStyle}"
                                                Click="OnDeleteRuleClicked"
                                                Tag="{x:Bind}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                <TextBlock Text="Delete rule" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
