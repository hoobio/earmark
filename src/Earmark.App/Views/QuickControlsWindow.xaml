<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Earmark.App.Views.QuickControlsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Earmark.App.ViewModels"
    xmlns:controls="using:Earmark.App.Controls"
    Title="Quick Controls">

    <Border x:Name="Root"
            Background="Transparent"
            IsTabStop="True">
        <Border.Resources>
            <!-- Compact card: the shared DeviceCardView with rules suppressed for the flyout. -->
            <DataTemplate x:Key="QuickCardTemplate" x:DataType="vm:DeviceCard">
                <Border Style="{StaticResource SectionCardStyle}" Padding="0">
                    <controls:DeviceCardView Card="{x:Bind}" ShowRules="False" />
                </Border>
            </DataTemplate>

            <!-- Compact group: an optional title over a vertical stack of member cards. -->
            <DataTemplate x:Key="QuickGroupTemplate" x:DataType="vm:DeviceGroupCard">
                <StackPanel Spacing="8">
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               Margin="2,0,0,0"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{x:Bind TitleVisibility, Mode=OneWay}" />
                    <ItemsRepeater ItemsSource="{x:Bind Members, Mode=OneWay}"
                                   ItemTemplate="{StaticResource QuickCardTemplate}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8" />
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
            </DataTemplate>

            <controls:BlockTemplateSelector x:Key="QuickBlockTemplateSelector"
                                            CardTemplate="{StaticResource QuickCardTemplate}"
                                            GroupTemplate="{StaticResource QuickGroupTemplate}" />
        </Border.Resources>

        <Grid>
            <Border x:Name="SolidBackdrop"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    Visibility="Collapsed" />

            <ScrollViewer x:Name="Scroller"
                          Margin="12"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          IsScrollInertiaEnabled="False"
                          Background="Transparent">
                <ItemsRepeater x:Name="Repeater">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="12" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <StaticResource ResourceKey="QuickBlockTemplateSelector" />
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
