<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Earmark.App.Views.QuickControlsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Earmark.App.ViewModels"
    xmlns:controls="using:Earmark.App.Controls"
    Title="Quick Controls">

    <Border x:Name="Root"
            Background="Transparent"
            IsTabStop="True">
        <Border.Resources>
            <!-- Compact card: the shared DeviceCardView with rules suppressed for the flyout. -->
            <DataTemplate x:Key="QuickCardTemplate" x:DataType="vm:DeviceCard">
                <Border Style="{StaticResource SectionCardStyle}"
                        Padding="0"
                        Opacity="{x:Bind CardOpacity, Mode=OneWay}">
                    <controls:DeviceCardView Card="{x:Bind}" ShowRules="False" />
                </Border>
            </DataTemplate>

            <!-- Compact group: an optional title over a vertical stack of member cards. A plain
                 ItemsControl (not a virtualizing ItemsRepeater): the member count is tiny, and a
                 virtualized inner list estimates off-screen rows at display time, inflating the scroll
                 extent (phantom whitespace + a stray recycled card) past the real content. -->
            <DataTemplate x:Key="QuickGroupTemplate" x:DataType="vm:DeviceGroupCard">
                <StackPanel Spacing="8">
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               Margin="2,0,0,0"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{x:Bind TitleVisibility, Mode=OneWay}" />
                    <ItemsControl ItemsSource="{x:Bind Members, Mode=OneWay}"
                                  ItemTemplate="{StaticResource QuickCardTemplate}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </StackPanel>
            </DataTemplate>

            <controls:BlockTemplateSelector x:Key="QuickBlockTemplateSelector"
                                            CardTemplate="{StaticResource QuickCardTemplate}"
                                            GroupTemplate="{StaticResource QuickGroupTemplate}" />
        </Border.Resources>

        <Grid>
            <Border x:Name="SolidBackdrop"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    Visibility="Collapsed" />

            <!-- ScrollView (not ScrollViewer): InteractionTracker-based, so the mouse wheel animates
                 smoothly out of the box. It fills the window so its scrollbar rides the window edge;
                 the 12px content inset lives in Padding, leaving a gutter the scrollbar overlays
                 instead of the cards. -->
            <ScrollView x:Name="Scroller"
                        Padding="12"
                        VerticalScrollBarVisibility="Auto"
                        ContentOrientation="Vertical"
                        Background="Transparent">
                <ItemsRepeater x:Name="Repeater">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="12" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <StaticResource ResourceKey="QuickBlockTemplateSelector" />
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollView>
        </Grid>
    </Border>
</Window>
