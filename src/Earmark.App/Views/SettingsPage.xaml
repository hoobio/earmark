<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Earmark.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Earmark.App.ViewModels"
    xmlns:ctrl="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:Windows.UI"
    Background="Transparent">

    <Page.Resources>
        <!-- One row in the hidden-apps manage modal: friendly name + (muted) identity path + Unhide. -->
        <DataTemplate x:Key="HiddenAppRowTemplate" x:DataType="vm:HiddenAppRow">
            <Grid ColumnSpacing="{StaticResource SpacingMedium}" Padding="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="{StaticResource SpacingXXSmall}">
                    <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                    <TextBlock Text="{x:Bind Detail}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Visibility="{x:Bind HasDetail, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Unhide"
                        Click="OnUnhideApp"
                        Tag="{x:Bind}"
                        VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" Style="{StaticResource PageHeaderTextStyle}" Margin="0,12,0,16" />

        <ScrollViewer Grid.Row="1" Padding="0,0,16,0">
            <StackPanel Spacing="{StaticResource SpacingSmall}" MaxWidth="720" HorizontalAlignment="Stretch">

                <TextBlock Text="General" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ctrl:SettingsCard Header="Launch on startup" Description="Start Earmark automatically when you sign in to Windows.">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.LaunchOnStartup, Mode=TwoWay}" />
                </ctrl:SettingsCard>

                <TextBlock Text="Appearance" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
                <ctrl:SettingsCard Header="Theme" Description="Choose a light or dark appearance, or follow the Windows setting.">
                    <ComboBox SelectedIndex="{x:Bind ViewModel.AppThemeIndex, Mode=TwoWay}" MinWidth="140">
                        <ComboBoxItem Content="System" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </ctrl:SettingsCard>
                <ctrl:SettingsCard Header="Backdrop" Description="The window's background material. Mica tints the desktop wallpaper, Acrylic blurs whatever sits behind the window, and Solid is an opaque themed surface.">
                    <ComboBox SelectedIndex="{x:Bind ViewModel.BackdropIndex, Mode=TwoWay}" MinWidth="140">
                        <ComboBoxItem Content="Mica" />
                        <ComboBoxItem Content="Acrylic" />
                        <ComboBoxItem Content="Solid" />
                    </ComboBox>
                </ctrl:SettingsCard>

                <TextBlock Text="Devices" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
                <ctrl:SettingsExpander Header="App indicators"
                                       Description="Show a chip for each app playing through a device, on that device's card. Drag a chip onto another card to reroute the app."
                                       IsExpanded="{x:Bind ViewModel.ShowAppIndicators, Mode=OneWay}">
                    <ctrl:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE71D;" />
                    </ctrl:SettingsExpander.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.ShowAppIndicators, Mode=TwoWay}" />
                    <ctrl:SettingsExpander.Items>
                        <ctrl:SettingsCard Header="Volume meters"
                                           Description="Show the thin peak-level bar under each app icon. Off drops the bar and makes the chips a little smaller."
                                           IsEnabled="{x:Bind ViewModel.AppIndicatorChildrenEnabled, Mode=OneWay}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.ShowAppPeakMeters, Mode=TwoWay}" />
                        </ctrl:SettingsCard>
                        <ctrl:SettingsCard Header="Hide audio forwarders"
                                           Description="Hide virtual cables and mixers (Wave Link, VB-Cable, Voicemeeter, SteelSeries Sonar, and similar) that just relay other apps' audio. Off shows them like any other app."
                                           IsEnabled="{x:Bind ViewModel.AppIndicatorChildrenEnabled, Mode=OneWay}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.FilterAudioForwarders, Mode=TwoWay}" />
                        </ctrl:SettingsCard>
                        <ctrl:SettingsCard Header="Keep stopped apps visible"
                                           Description="After an app stops playing or closes, its chip dims and lingers for this many seconds before it disappears. Closed apps also show a badge. Set 0 to remove a chip as soon as its app stops."
                                           IsEnabled="{x:Bind ViewModel.AppIndicatorChildrenEnabled, Mode=OneWay}">
                            <NumberBox Value="{x:Bind ViewModel.AppChipLingerSeconds, Mode=TwoWay}"
                                       Minimum="0" Maximum="600"
                                       SpinButtonPlacementMode="Inline"
                                       SmallChange="5" LargeChange="30"
                                       MinWidth="140" />
                        </ctrl:SettingsCard>
                        <ctrl:SettingsCard Header="Hidden apps"
                                           Description="{x:Bind ViewModel.HiddenAppsDescription, Mode=OneWay}"
                                           IsEnabled="{x:Bind ViewModel.AppIndicatorChildrenEnabled, Mode=OneWay}">
                            <ctrl:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xED1A;" />
                            </ctrl:SettingsCard.HeaderIcon>
                            <Button Content="Manage" Click="OnManageHiddenApps" />
                        </ctrl:SettingsCard>
                    </ctrl:SettingsExpander.Items>
                </ctrl:SettingsExpander>

                <ctrl:SettingsExpander Header="Peak meter"
                                       Description="The level meter behind each device's volume slider. Off hides it and shows a plain slider.">
                    <ComboBox SelectedIndex="{x:Bind ViewModel.PeakMeterColourModeIndex, Mode=TwoWay}" MinWidth="150">
                        <ComboBoxItem Content="Gradient" />
                        <ComboBoxItem Content="Blocks" />
                        <ComboBoxItem Content="Single colour" />
                        <ComboBoxItem Content="Off" />
                    </ComboBox>
                    <ctrl:SettingsExpander.Items>
                        <ctrl:SettingsCard Header="Bar colour"
                                           Description="Colour for the Single colour mode. Pick a quick swatch or open the wheel for a custom colour."
                                           IsEnabled="{x:Bind ViewModel.IsSingleColourMode, Mode=OneWay}">
                            <Button MinWidth="140" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                    <Border Width="24" Height="16"
                                            CornerRadius="{ThemeResource ControlCornerRadius}"
                                            BorderThickness="1"
                                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                            Background="{x:Bind ViewModel.PeakMeterSingleColour, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" />
                                    <TextBlock Text="Choose…" VerticalAlignment="Center" />
                                </StackPanel>
                                <Button.Flyout>
                                    <Flyout>
                                        <StackPanel Spacing="{StaticResource SpacingMedium}" Width="296">
                                            <TextBlock Text="Quick colours"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <ItemsControl ItemsSource="{x:Bind MeterSwatches}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingXSmall}" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="ui:Color">
                                                        <Button Width="28" Height="28"
                                                                Padding="0"
                                                                Click="OnMeterSwatchClick"
                                                                Tag="{x:Bind}"
                                                                HorizontalContentAlignment="Stretch"
                                                                VerticalContentAlignment="Stretch">
                                                            <Border CornerRadius="{ThemeResource ControlCornerRadius}"
                                                                    Background="{x:Bind Converter={StaticResource ColorToBrushConverter}}" />
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ColorPicker x:Name="MeterColorPicker"
                                                         Color="{x:Bind ViewModel.PeakMeterSingleColour, Mode=TwoWay}"
                                                         ColorSpectrumShape="Ring"
                                                         IsAlphaEnabled="False"
                                                         IsMoreButtonVisible="True"
                                                         IsColorSliderVisible="True"
                                                         IsColorChannelTextInputVisible="False"
                                                         IsHexInputVisible="True" />
                                            <Button Content="Reset to default"
                                                    Click="OnResetMeterColour"
                                                    HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </ctrl:SettingsCard>
                        <ctrl:SettingsCard Header="Channels"
                                           Description="Split shows a bar per channel group (L / Centre+LFE / R); Single shows one combined bar from the loudest channel."
                                           IsEnabled="{x:Bind ViewModel.IsMeterEnabled, Mode=OneWay}">
                            <ComboBox SelectedIndex="{x:Bind ViewModel.PeakMeterChannelModeIndex, Mode=TwoWay}" MinWidth="150">
                                <ComboBoxItem Content="Split" />
                                <ComboBoxItem Content="Single" />
                            </ComboBox>
                        </ctrl:SettingsCard>
                        <ctrl:SettingsCard Header="Peak-hold tick"
                                           Description="Show the line that marks the recent loudest peak (it turns red on clipping)."
                                           IsEnabled="{x:Bind ViewModel.IsMeterEnabled, Mode=OneWay}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.PeakMeterShowHold, Mode=TwoWay}" />
                        </ctrl:SettingsCard>
                    </ctrl:SettingsExpander.Items>
                </ctrl:SettingsExpander>

                <TextBlock Text="System tray" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
                <ctrl:SettingsExpander Header="Show tray icon"
                                       Description="Display the Earmark icon in the Windows notification area. The behaviours below need it on."
                                       IsExpanded="{x:Bind ViewModel.ShowTrayIcon, Mode=OneWay}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.ShowTrayIcon, Mode=TwoWay}" />
                    <ctrl:SettingsExpander.Items>
                        <ctrl:SettingsCard Header="Minimize to tray"
                                           Description="Minimizing the window hides it to the tray instead of the taskbar."
                                           IsEnabled="{x:Bind ViewModel.ShowTrayIcon, Mode=OneWay}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}" />
                        </ctrl:SettingsCard>
                        <ctrl:SettingsCard Header="Close to tray"
                                           Description="Closing the window keeps Earmark running in the tray. Use the tray menu to quit."
                                           IsEnabled="{x:Bind ViewModel.ShowTrayIcon, Mode=OneWay}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.CloseToTray, Mode=TwoWay}" />
                        </ctrl:SettingsCard>
                        <ctrl:SettingsCard Header="Launch to tray"
                                           Description="Skip showing the window on startup and run silently in the tray."
                                           IsEnabled="{x:Bind ViewModel.ShowTrayIcon, Mode=OneWay}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.LaunchToTray, Mode=TwoWay}" />
                        </ctrl:SettingsCard>
                    </ctrl:SettingsExpander.Items>
                </ctrl:SettingsExpander>

                <TextBlock Text="Wave Link" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
                <ctrl:SettingsExpander Header="Wave Link integration"
                                       Description="Route Wave Link mix outputs from rules. Earmark connects to Wave Link's local WebSocket while the integration is on."
                                       IsExpanded="{x:Bind ViewModel.EnableWaveLink, Mode=OneWay}">
                    <ctrl:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE767;" />
                    </ctrl:SettingsExpander.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10"
                                 Fill="{x:Bind ViewModel.WaveLinkState, Mode=OneWay, Converter={StaticResource WaveLinkStateBrushConverter}}"
                                 VerticalAlignment="Center"
                                 ToolTipService.ToolTip="{x:Bind ViewModel.WaveLinkStatusText, Mode=OneWay}" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.EnableWaveLink, Mode=TwoWay}" />
                    </StackPanel>
                    <ctrl:SettingsExpander.Items>
                        <!-- "Reconcile device names" is hidden: it writes the Windows endpoint
                             FriendlyName, which Windows blocks for clients (IPropertyStore SetValue
                             returns E_ACCESSDENIED even elevated), so it can only ever no-op or fail.
                             VM property / setting / WaveLinkNameReconciler are kept dormant for a
                             future elevated registry-based revival. -->
                        <ctrl:SettingsCard Header="Channel style"
                                           Description="Borrow each Wave Link channel's look for its device card. Colours tints the icon tile with the channel's accent; Icons swaps in the channel's own Wave Link artwork in place of the Fluent glyph."
                                           IsEnabled="{x:Bind ViewModel.EnableWaveLink, Mode=OneWay}">
                            <ComboBox SelectedIndex="{x:Bind ViewModel.WaveLinkChannelStyleIndex, Mode=TwoWay}"
                                      MinWidth="140">
                                <ComboBoxItem Content="Off" />
                                <ComboBoxItem Content="Colours" />
                                <ComboBoxItem Content="Icons" />
                            </ComboBox>
                        </ctrl:SettingsCard>
                    </ctrl:SettingsExpander.Items>
                </ctrl:SettingsExpander>

                <TextBlock Text="Diagnostics" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
                <ctrl:SettingsCard Header="Verbose logging" Description="Write debug-level diagnostics to the log file. Leave off for normal use.">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.VerboseLogging, Mode=TwoWay}" />
                </ctrl:SettingsCard>
                <ctrl:SettingsCard Header="Logs"
                                   Description="Open the folder with Earmark's log files (one per launch). To capture a useful log for a bug report, turn on Verbose logging above, reproduce the issue, then attach the latest file.">
                    <ctrl:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </ctrl:SettingsCard.HeaderIcon>
                    <Button Content="Open logs folder" Click="OnOpenLogsFolder" />
                </ctrl:SettingsCard>

                <TextBlock Text="Help &amp; feedback" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
                <ctrl:SettingsCard Header="Report a bug"
                                   Description="Open a pre-filled bug report on GitHub.">
                    <ctrl:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xED15;" />
                    </ctrl:SettingsCard.HeaderIcon>
                    <Button Content="Report a bug" Click="OnReportBug" />
                </ctrl:SettingsCard>
                <ctrl:SettingsCard Header="Request a feature"
                                   Description="Suggest an improvement or a new rule type.">
                    <ctrl:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE710;" />
                    </ctrl:SettingsCard.HeaderIcon>
                    <Button Content="Request a feature" Click="OnRequestFeature" />
                </ctrl:SettingsCard>
                <ctrl:SettingsCard Header="Project on GitHub"
                                   Description="Source, releases, and existing issues.">
                    <ctrl:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8A7;" />
                    </ctrl:SettingsCard.HeaderIcon>
                    <Button Content="View on GitHub" Click="OnOpenGitHub" />
                </ctrl:SettingsCard>

                <TextBlock Text="About" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
                <ctrl:SettingsCard Header="Earmark" Description="{x:Bind About.BuildInfo}">
                    <ctrl:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE946;" />
                    </ctrl:SettingsCard.HeaderIcon>
                </ctrl:SettingsCard>
                <ctrl:SettingsCard Header="Check for updates"
                                   Description="{x:Bind About.UpdateStatusText, Mode=OneWay}"
                                   Visibility="{x:Bind About.IsUpdateCheckSupported, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ctrl:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE895;" />
                    </ctrl:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                        <Button Content="View release"
                                Click="OnOpenLatestRelease"
                                Style="{ThemeResource AccentButtonStyle}"
                                Visibility="{x:Bind About.UpdateAvailable, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="Check now"
                                Click="OnCheckForUpdates"
                                IsEnabled="{x:Bind About.CanCheck, Mode=OneWay}" />
                    </StackPanel>
                </ctrl:SettingsCard>
                <ctrl:SettingsCard Header="Check automatically on launch"
                                   Description="{x:Bind About.AutoCheckDescription}"
                                   IsEnabled="{x:Bind About.IsAutoCheckEnabled}"
                                   Visibility="{x:Bind About.IsUpdateCheckSupported, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ToggleSwitch IsOn="{x:Bind About.AutoCheckForUpdates, Mode=TwoWay}" />
                </ctrl:SettingsCard>

            </StackPanel>
        </ScrollViewer>

        <!-- Hidden-apps manage modal. Lives in the visual tree (not Page.Resources) so its x:Binds
             compile; ContentDialog renders nothing until ShowAsync, so it claims no layout. -->
        <ContentDialog x:Name="HiddenAppsDialog"
                       Grid.RowSpan="2"
                       Title="Hidden apps"
                       CloseButtonText="Done"
                       DefaultButton="Close">
            <Grid MinWidth="380" RowSpacing="{StaticResource SpacingMedium}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="These apps don't show a chip on any device. Unhide one to bring its chip back."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="1"
                           Text="No apps are hidden."
                           Style="{StaticResource MutedCaptionTextStyle}"
                           Margin="0,4,0,0"
                           Visibility="{x:Bind ViewModel.NoHiddenApps, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.HiddenApps, Mode=OneWay}"
                          ItemTemplate="{StaticResource HiddenAppRowTemplate}"
                          SelectionMode="None"
                          MaxHeight="320"
                          Visibility="{x:Bind ViewModel.HasHiddenApps, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
                <Button Grid.Row="2"
                        Content="Clear all"
                        Click="OnClearAllHiddenApps"
                        HorizontalAlignment="Right"
                        Visibility="{x:Bind ViewModel.HasHiddenApps, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </ContentDialog>
    </Grid>
</Page>
