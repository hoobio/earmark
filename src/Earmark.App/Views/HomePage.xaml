<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Earmark.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Earmark.App.ViewModels"
    xmlns:controls="using:Earmark.App.Controls"
    Background="Transparent"
    KeyboardAcceleratorPlacementMode="Hidden">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="OnUndoInvoked" />
    </Page.KeyboardAccelerators>

    <Page.Resources>
        <!-- Lone device card. Shared between the top-level block list (a lone card) and a group
             container's inner member repeater, so both render identically. The card body is the
             reusable DeviceCardView; this Border adds the drop target + drag source chrome. -->
        <DataTemplate x:Key="DeviceCardTemplate" x:DataType="vm:DeviceCard">
            <Border Style="{StaticResource SectionCardStyle}"
                    Padding="0"
                    Opacity="{x:Bind CardOpacity, Mode=OneWay}"
                    controls:WrapByRowLayout.IsCustomSized="{x:Bind IsLayoutCustomSized, Mode=OneWay}"
                    AllowDrop="True"
                    CanDrag="True"
                    Tag="{x:Bind}"
                    PointerEntered="OnDeviceCardPointerEntered"
                    PointerExited="OnDeviceCardPointerExited"
                    DragStarting="OnDeviceCardDragStarting"
                    DropCompleted="OnDeviceCardDropCompleted"
                    DragOver="OnDeviceCardDragOver"
                    Drop="OnDeviceCardDrop">
                <controls:DeviceCardView Card="{x:Bind}" RenameGroupRequested="OnCardRenameGroupRequested" />
            </Border>
        </DataTemplate>

        <!-- Group container block. Transparent at rest; the dotted outline shows only while a drag
             is in flight. The title sits in a band above its members, which are laid out by a nested
             WrapByRowLayout - because the outer BlockWrapLayout sizes this container to exactly
             span*columnWidth+gaps, the inner layout recomputes the same column width and the members
             line up with lone cards. -->
        <DataTemplate x:Key="DeviceGroupCardTemplate" x:DataType="vm:DeviceGroupCard">
            <!-- Block root: a full-width section (it claims its own row), but the group box inside is
                 left-aligned and sized to the members' real extent, so the dotted outline + drag
                 snapshot bound to the cards, not the empty trailing columns. -->
            <Grid Opacity="{x:Bind Opacity, Mode=OneWay}">
                <Grid HorizontalAlignment="Left">
                    <!-- Padded content: a fixed 28px title band then the members. ContentPadding gives
                         the outline breathing room around the cards while dragging (zero at rest). -->
                    <Grid Padding="{x:Bind ContentPadding, Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{x:Bind TitleRowHeight, Mode=OneWay}" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Title band. Doubles as the group's drag handle (drag to reorder the whole
                             section); double-tap / context "Rename" edits the title; context "Ungroup
                             all" disbands the group. -->
                        <Grid x:Name="GroupTitleBand"
                            Grid.Row="0" Padding="2,0,4,0"
                                                            Background="{ThemeResource GroupTitleBandBackgroundBrush}"
                              CanDrag="True"
                              Tag="{x:Bind}"
                              DragStarting="OnGroupHeaderDragStarting"
                              DropCompleted="OnGroupHeaderDropCompleted"
                              DoubleTapped="OnGroupTitleDoubleTapped"
                              Visibility="{x:Bind ShowTitleBand, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                              ToolTipService.ToolTip="Drag to move the group · double-click to rename">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Rename group" Click="OnRenameGroupClicked" Tag="{x:Bind}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8AC;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Delete group" Click="OnUngroupAllClicked" Tag="{x:Bind}">
                                        <!-- Critical red across rest/hover/press so the destructive action
                                             reads as destructive; the default template would otherwise swap
                                             the foreground to the neutral theme brush on pointer-over. -->
                                        <MenuFlyoutItem.Resources>
                                            <SolidColorBrush x:Key="MenuFlyoutItemForeground" Color="{ThemeResource SystemFillColorCritical}" />
                                            <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="{ThemeResource SystemFillColorCritical}" />
                                            <SolidColorBrush x:Key="MenuFlyoutItemForegroundPressed" Color="{ThemeResource SystemFillColorCritical}" />
                                        </MenuFlyoutItem.Resources>
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Top"
                                        Visibility="{x:Bind ShowTitleLabel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                           VerticalAlignment="Top"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap" />
                            </StackPanel>
                            <TextBox Text="{x:Bind Title, Mode=TwoWay}"
                                     Visibility="{x:Bind IsEditingTitle, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     Tag="{x:Bind}"
                                     MinHeight="0"
                                     PlaceholderText="Group name"
                                     KeyDown="OnGroupTitleKeyDown"
                                     LostFocus="OnGroupTitleEditLostFocus"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     VerticalContentAlignment="Center"
                                     FontWeight="SemiBold"
                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>

                        <!-- Members. The inner repeater reuses the lone-card template + WrapByRowLayout
                             so members render identically and align to the same column grid; left-
                             aligned + content-width so the box hugs them. -->
                        <ItemsRepeater Grid.Row="1"
                                       HorizontalAlignment="Left"
                                       ItemsSource="{x:Bind Members, Mode=OneWay}"
                                       ElementPrepared="OnBlockElementPrepared"
                                       ItemTemplate="{StaticResource DeviceCardTemplate}">
                            <ItemsRepeater.Layout>
                                <controls:WrapByRowLayout MinItemWidth="320"
                                                          ColumnSpacing="{StaticResource SpacingMedium}"
                                                          RowSpacing="{StaticResource SpacingMedium}" />
                            </ItemsRepeater.Layout>
                        </ItemsRepeater>
                    </Grid>

                    <!-- Dotted outline at the group-box bounds (non-interactive). Only one is ever
                         visible: neutral while dragging, accent when this group is the join target. -->
                    <Rectangle RadiusX="{StaticResource CardCornerRadiusValue}" RadiusY="{StaticResource CardCornerRadiusValue}"
                               Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                               StrokeThickness="1"
                               StrokeDashArray="3,3"
                               IsHitTestVisible="False"
                               Visibility="{x:Bind ShowNeutralOutline, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Rectangle RadiusX="{StaticResource CardCornerRadiusValue}" RadiusY="{StaticResource CardCornerRadiusValue}"
                               Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                               StrokeThickness="2"
                               StrokeDashArray="3,3"
                               IsHitTestVisible="False"
                               Visibility="{x:Bind IsJoinTarget, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <!-- No page-level horizontal padding: the scroll region runs full-width so its scrollbar sits on
         the window edge (matching Windows Settings). The header and the scroll *content* carry the
         28px side inset instead, so cards line up under the header while the scrollbar hugs the edge. -->
    <Grid x:Name="DevicesRootGrid" Background="Transparent">
        <!-- Right-click the page background (not a card) for page options; the floating "..." (top
             right, auto-hides) holds the same items. Card right-clicks show the card's own menu. -->
        <Grid.ContextFlyout>
            <MenuFlyout>
                <ToggleMenuFlyoutItem Text="Show title bar" IsChecked="{x:Bind ViewModel.ShowDevicesHeader, Mode=TwoWay}" />
                <ToggleMenuFlyoutItem Text="Show rules" IsChecked="{x:Bind ViewModel.ShowRules, Mode=TwoWay}" />
                <ToggleMenuFlyoutItem Text="Show hidden devices" IsChecked="{x:Bind ViewModel.ShowHiddenDevices, Mode=TwoWay}" />
                <ToggleMenuFlyoutItem Text="Show disconnected devices" IsChecked="{x:Bind ViewModel.ShowDisconnectedDevices, Mode=TwoWay}" />
                <ToggleMenuFlyoutItem Text="Lock layout" IsChecked="{x:Bind ViewModel.LockLayout, Mode=TwoWay}" />
            </MenuFlyout>
        </Grid.ContextFlyout>

        <!-- Full-bleed content: cards scroll up to the window title bar; loading / empty overlay it. -->
        <Grid>
            <!-- Loading: shown while the first device enumeration is in flight, so the empty
                 state below isn't mistaken for "no devices". Full-bleed and transparent (no card
                 chrome) so the ring sits centred on the natural page background, not an inset box -
                 a seamless continuation of the window's startup skeleton. -->
            <Grid Visibility="{x:Bind ViewModel.ShowLoadingState, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Spacing="{StaticResource SpacingMedium}" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressRing IsActive="{x:Bind ViewModel.ShowLoadingState, Mode=OneWay}"
                                  Width="32" Height="32" HorizontalAlignment="Center" />
                    <TextBlock Text="Loading devices…"
                               Style="{StaticResource MutedCaptionTextStyle}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Empty (genuine): no devices exist at all, live or remembered. -->
            <Border Style="{StaticResource SectionCardStyle}"
                    Padding="32"
                    Margin="{StaticResource DevicesPlaceholderMargin}"
                    Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Spacing="{StaticResource SpacingMedium}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                    <FontIcon Glyph="&#xE767;" FontSize="40"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="No audio devices"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Style="{StaticResource MutedCaptionTextStyle}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Text="Earmark couldn't find any audio devices on this PC." />
                </StackPanel>
            </Border>

            <!-- Filtered-empty: devices DO exist but they're all hidden / disconnected with the
                 matching toggle off. Point at the toggles rather than implying there are no devices. -->
            <Border Style="{StaticResource SectionCardStyle}"
                    Padding="32"
                    Margin="{StaticResource DevicesPlaceholderMargin}"
                    Visibility="{x:Bind ViewModel.ShowFilteredEmptyState, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Spacing="{StaticResource SpacingMedium}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440">
                    <FontIcon Glyph="&#xED1A;" FontSize="40"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="Nothing to show"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Style="{StaticResource MutedCaptionTextStyle}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Text="Every device is hidden or disconnected. Right-click (or use the ··· menu) and turn on Show hidden devices or Show disconnected devices to reveal them." />
                </StackPanel>
            </Border>

            <!-- The scroll viewer fills the row edge-to-edge so its (overlay) scrollbar rides the
                 window edge like Settings, and its padding is sides-only so content scrolls flush to
                 the window's bottom edge (no dead band that clips cards short mid-scroll). The trailing
                 breathing room lives on the list itself (DevicesRepeater.Margin) so only the last card
                 clears the bottom edge when fully scrolled. -->
            <ScrollViewer x:Name="DevicesScroller"
                          Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="{StaticResource DevicesScrollPadding}"
                          VerticalContentAlignment="Top">
                <!-- Scroll content: an optional "Devices" title header (scrolls away) above the drop
                     surface. The top inset aligns the first content row (the "Devices" title, or the
                     first group / card when the header is hidden) with the top of the first nav-rail
                     item - both regions share the NavigationView's title-bar TopPadding, so this small
                     inset is what matches the title's cap to the icon-centred nav row. -->
                <StackPanel Padding="0">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" Margin="0,0,0,16"
                                Visibility="{x:Bind ViewModel.ShowDevicesHeader, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Devices" Style="{StaticResource PageHeaderTextStyle}" />
                        <FontIcon Glyph="&#xE946;" FontSize="14"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  VerticalAlignment="Center"
                                  ToolTipService.ToolTip="Audio endpoints on this PC. Default devices appear first. Use the slider to set master volume; rule-controlled volumes are read-only. Devices without rules are hidden by default unless they're the system default." />
                    </StackPanel>

                    <!-- Transparent drop surface around the repeater: block reorder is handled here (not
                         per-card) so the insertion point is computed from the layout's frozen no-gap
                         geometry. That keeps it stable while blocks slide to open the gap, and catches a
                         drop over the empty gap or past the last block. App-chip drops stay per-card. -->
                    <Grid Background="Transparent"
                          AllowDrop="True"
                          DragOver="OnBlocksDragOver"
                          Drop="OnBlocksDrop"
                          Tapped="OnContentTapped">
                        <ItemsRepeater x:Name="DevicesRepeater"
                                       ItemsSource="{x:Bind ViewModel.Blocks}"
                                       ElementPrepared="OnBlockElementPrepared"
                                       Margin="{StaticResource DevicesListBottomMargin}"
                                       VerticalAlignment="Top">
                            <ItemsRepeater.Layout>
                                <controls:BlockWrapLayout MinItemWidth="320"
                                                          ColumnSpacing="{StaticResource SpacingMedium}"
                                                          RowSpacing="{StaticResource SpacingMedium}" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <controls:BlockTemplateSelector CardTemplate="{StaticResource DeviceCardTemplate}"
                                                                GroupTemplate="{StaticResource DeviceGroupCardTemplate}" />
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Floating overflow "...": top-most, top-right, with a symmetric inset. Auto-hides unless the
             pointer is over the page, it's keyboard-focused, or its menu is open (wired in code-behind).
             Cards may scroll under it - it sits above them and stays clickable. -->
        <Button x:Name="OverflowButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,16,16,0"
                Width="40"
                Height="36"
                Padding="0"
                Opacity="0"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                ToolTipService.ToolTip="Page options"
                GotFocus="OnOverflowFocusChanged"
                LostFocus="OnOverflowFocusChanged">
            <FontIcon Glyph="&#xE712;" FontSize="16" />
            <Button.Flyout>
                <MenuFlyout Opening="OnOverflowFlyoutOpening" Closed="OnOverflowFlyoutClosed">
                    <ToggleMenuFlyoutItem Text="Show title bar" IsChecked="{x:Bind ViewModel.ShowDevicesHeader, Mode=TwoWay}" />
                    <ToggleMenuFlyoutItem Text="Show rules" IsChecked="{x:Bind ViewModel.ShowRules, Mode=TwoWay}" />
                    <ToggleMenuFlyoutItem Text="Show hidden devices" IsChecked="{x:Bind ViewModel.ShowHiddenDevices, Mode=TwoWay}" />
                    <ToggleMenuFlyoutItem Text="Show disconnected devices" IsChecked="{x:Bind ViewModel.ShowDisconnectedDevices, Mode=TwoWay}" />
                    <ToggleMenuFlyoutItem Text="Lock layout" IsChecked="{x:Bind ViewModel.LockLayout, Mode=TwoWay}" />
                </MenuFlyout>
            </Button.Flyout>
        </Button>
    </Grid>
</Page>
