<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Earmark.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Earmark.App.ViewModels"
    xmlns:controls="using:Earmark.App.Controls"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    Background="Transparent"
    KeyboardAcceleratorPlacementMode="Hidden">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="OnUndoInvoked" />
    </Page.KeyboardAccelerators>

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Devices" Style="{StaticResource PageHeaderTextStyle}" />
                <FontIcon Glyph="&#xE946;" FontSize="14"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          VerticalAlignment="Center"
                          ToolTipService.ToolTip="Audio endpoints on this PC. Default devices appear first. Use the slider to set master volume; rule-controlled volumes are read-only. Devices without rules are hidden by default unless they're the system default." />
            </StackPanel>

            <ToggleSwitch Grid.Column="1"
                          IsOn="{x:Bind ViewModel.ShowHiddenDevices, Mode=TwoWay}"
                          OffContent="Show hidden"
                          OnContent="Show hidden"
                          MinWidth="0"
                          VerticalAlignment="Center"
                          ToolTipService.ToolTip="Reveal devices with no rules and devices you've hidden" />
        </Grid>

        <Grid Grid.Row="1">
            <!-- Empty -->
            <Border Style="{StaticResource SectionCardStyle}"
                    Padding="32"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                    <FontIcon Glyph="&#xE767;" FontSize="40"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="Nothing to show"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Style="{StaticResource MutedCaptionTextStyle}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Text="No devices have rules associated with them yet. Add a rule, or flip 'Show hidden' to reveal everything." />
                </StackPanel>
            </Border>

            <ScrollViewer Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalContentAlignment="Top">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Devices}"
                               VerticalAlignment="Top">
                    <ItemsRepeater.Layout>
                        <controls:WrapByRowLayout MinItemWidth="320"
                                                  ColumnSpacing="12"
                                                  RowSpacing="12" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:DeviceCard">
                            <Border Style="{StaticResource SectionCardStyle}"
                                    Opacity="{x:Bind CardOpacity, Mode=OneWay}"
                                    controls:WrapByRowLayout.IsCustomSized="{x:Bind IsLayoutCustomSized, Mode=OneWay}"
                                    AllowDrop="True"
                                    Tag="{x:Bind}"
                                    DragOver="OnDeviceCardDragOver"
                                    Drop="OnDeviceCardDrop">
                                <StackPanel Spacing="12">
                                    <!-- Header: mute toggle (icon) + name + chips + hide toggle -->
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- The Border wrapper carries ToolTipService.ToolTip so the lock-reason
                                             tooltip still fires when the inner Button is disabled (rule-locked).
                                             WinUI suppresses tooltips on disabled controls; a transparent
                                             hit-testable parent is the standard workaround. -->
                                        <Border Grid.Column="0"
                                                Background="Transparent"
                                                ToolTipService.ToolTip="{x:Bind MuteTooltip, Mode=OneWay}">
                                            <Button Width="56" Height="56"
                                                    Padding="0"
                                                    Background="{x:Bind IsMuteLockedByRule, Mode=OneWay, Converter={StaticResource MuteLockedBackgroundConverter}}"
                                                    BorderBrush="Transparent"
                                                    CornerRadius="10"
                                                    Tag="{x:Bind}"
                                                    IsEnabled="{x:Bind IsMuteToggleEnabled, Mode=OneWay}"
                                                    Click="OnMuteToggleClicked"
                                                    ToolTipService.ToolTip="{x:Bind MuteTooltip, Mode=OneWay}">
                                                <!-- Disabled-state theme brushes paint over the Background binding when
                                                     IsEnabled is false (i.e. rule-locked). Override them so a locked
                                                     icon reads as "not interactive" rather than a dimmed chip. -->
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                                                </Button.Resources>
                                                <FontIcon Glyph="{x:Bind Glyph, Mode=OneWay}"
                                                          FontSize="28"
                                                          Foreground="{x:Bind IsMuted, Mode=OneWay, Converter={StaticResource MutedBrushConverter}}" />
                                            </Button>
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind DeviceNameOnly}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTipService.ToolTip="{x:Bind DisplayName}" />
                                            <TextBlock Text="{x:Bind DeviceIdSubtext}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{x:Bind HasDeviceIdSubtext}" />
                                            <!-- Negative left margin compensates for the ChipBorderStyle's 8px
                                                 horizontal padding so pill text starts on the same x as the
                                                 subtitle above it. Top margin gives the row a little breathing
                                                 space below the subtitle so the three lines don't read crammed. -->
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6"
                                                        Margin="-8,4,0,0">
                                                <Border Padding="8,2"
                                                        VerticalAlignment="Center"
                                                        Visibility="{x:Bind ShowFlowLabel}">
                                                    <TextBlock Text="{x:Bind FlowLabel}"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Border>
                                                <Border Style="{StaticResource ChipBorderStyle}"
                                                        Visibility="{x:Bind IsDefault}">
                                                    <TextBlock Text="{x:Bind DefaultPillText}"
                                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                                </Border>
                                                <Border Style="{StaticResource ChipBorderStyle}"
                                                        Visibility="{x:Bind IsDefaultCommunications}">
                                                    <TextBlock Text="{x:Bind CommunicationsPillText}"
                                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Style="{StaticResource GhostIconButtonStyle}"
                                                Command="{x:Bind ToggleUserVisibilityCommand}"
                                                VerticalAlignment="Top"
                                                ToolTipService.ToolTip="{x:Bind HideToggleTooltip, Mode=OneWay}">
                                            <FontIcon Glyph="{x:Bind HideToggleGlyph, Mode=OneWay}"
                                                      FontSize="14" />
                                        </Button>
                                    </Grid>

                                    <!-- Volume row -->
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Peak meter sits behind the slider; slider track brushes are
                                             overridden in scope to be transparent so the meter shows through.
                                             Opacity dims when muted (still hit-testable so a drag unmutes). -->
                                        <Grid Grid.Column="0" Height="28"
                                              Opacity="{x:Bind VolumeAreaOpacity, Mode=OneWay}">
                                            <Grid.Resources>
                                                <SolidColorBrush x:Key="SliderTrackFill" Color="Transparent" />
                                                <SolidColorBrush x:Key="SliderTrackValueFill" Color="Transparent" />
                                                <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="Transparent" />
                                                <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="Transparent" />
                                                <SolidColorBrush x:Key="SliderTrackFillPressed" Color="Transparent" />
                                                <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="Transparent" />
                                                <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="Transparent" />
                                                <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="Transparent" />
                                            </Grid.Resources>

                                            <!-- Sectioned peak meter: bar width = peak * volume, split into colour
                                                 bands at fixed audio thresholds. A peak-hold marker overlays the same
                                                 track region and latches at the most recent high. -->
                                            <Border Height="10"
                                                    CornerRadius="5"
                                                    Margin="8,0"
                                                    Background="{ThemeResource ControlAltFillColorTertiaryBrush}"
                                                    VerticalAlignment="Center"
                                                    IsHitTestVisible="False">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{x:Bind GreenStars, Mode=OneWay}" />
                                                        <ColumnDefinition Width="{x:Bind GreenYellowBlendStars, Mode=OneWay}" />
                                                        <ColumnDefinition Width="{x:Bind YellowStars, Mode=OneWay}" />
                                                        <ColumnDefinition Width="{x:Bind YellowRedBlendStars, Mode=OneWay}" />
                                                        <ColumnDefinition Width="{x:Bind RedStars, Mode=OneWay}" />
                                                        <ColumnDefinition Width="{x:Bind MeterRemainderStars, Mode=OneWay}" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Background="{ThemeResource SystemFillColorSuccessBrush}" />
                                                    <Border Grid.Column="1">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                <GradientStop Color="{ThemeResource SystemFillColorSuccess}" Offset="0" />
                                                                <GradientStop Color="{ThemeResource SystemFillColorCaution}" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <Border Grid.Column="2"
                                                            Background="{ThemeResource SystemFillColorCautionBrush}" />
                                                    <Border Grid.Column="3">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                <GradientStop Color="{ThemeResource SystemFillColorCaution}" Offset="0" />
                                                                <GradientStop Color="{ThemeResource SystemFillColorCritical}" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <Border Grid.Column="4"
                                                            Background="{ThemeResource SystemFillColorCriticalBrush}" />
                                                </Grid>
                                            </Border>

                                            <Border Height="14"
                                                    Margin="8,0"
                                                    VerticalAlignment="Center"
                                                    IsHitTestVisible="False"
                                                    Visibility="{x:Bind PeakHoldVisibility, Mode=OneWay}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{x:Bind PeakHoldLeftStars, Mode=OneWay}" />
                                                        <ColumnDefinition Width="{x:Bind PeakHoldRightStars, Mode=OneWay}" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Width="2"
                                                            HorizontalAlignment="Right"
                                                            Background="{ThemeResource TextFillColorPrimaryBrush}" />
                                                </Grid>
                                            </Border>

                                            <Slider Minimum="0"
                                                    Maximum="100"
                                                    StepFrequency="1"
                                                    SmallChange="1"
                                                    LargeChange="5"
                                                    Value="{x:Bind VolumePercent, Mode=TwoWay}"
                                                    IsEnabled="{x:Bind IsVolumeEditable, Mode=OneWay}"
                                                    Tag="{x:Bind}"
                                                    PointerPressed="OnSliderPointerPressed"
                                                    PointerCaptureLost="OnSliderReleased"
                                                    KeyDown="OnSliderKeyDown"
                                                    KeyUp="OnSliderKeyUp"
                                                    LostFocus="OnSliderLostFocus"
                                                    VerticalAlignment="Center"
                                                    Background="Transparent" />

                                            <Border Background="Transparent"
                                                    Tapped="OnLockedSliderTapped"
                                                    ToolTipService.ToolTip="{x:Bind VolumeLockedTooltip, Mode=OneWay}"
                                                    Visibility="{x:Bind IsVolumeLocked, Mode=OneWay}" />
                                        </Grid>

                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind VolumePercentText, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   MinWidth="38"
                                                   TextAlignment="Right"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />

                                        <FontIcon Grid.Column="2"
                                                  Glyph="&#xE72E;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                  VerticalAlignment="Center"
                                                  ToolTipService.ToolTip="{x:Bind VolumeLockedTooltip, Mode=OneWay}"
                                                  Visibility="{x:Bind IsVolumeLockedByRule, Mode=OneWay}" />
                                    </Grid>

                                    <!-- Rule summary list: compact rule chips matching the Rules page shape.
                                         Collapsed by default to one chip; chevron expands the panel up to a cap.
                                         ItemsSource is bound to VisibleRules (collapsed=1 chip, expanded=all chips)
                                         so chips appearing/disappearing fire per-container Loaded, where we hook up
                                         composition implicit show/hide animations for a smooth fade. -->
                                    <StackPanel Spacing="4" Visibility="{x:Bind HasRules}">
                                        <TextBlock Text="Rules"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <ScrollViewer x:Name="RulesScroll"
                                                      MaxHeight="320"
                                                      VerticalScrollMode="Enabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{x:Bind VisibleRules, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:RuleSummary">
                                                        <Button Style="{StaticResource SubtleRuleChipButtonStyle}"
                                                                Margin="0,2,0,0"
                                                                Opacity="{x:Bind Opacity}"
                                                                Click="OnRuleChipClicked"
                                                                ToolTipService.ToolTip="Open in Rules">
                                                            <animations:Implicit.ShowAnimations>
                                                                <animations:OpacityAnimation From="0" To="1" Duration="0:0:0.18" />
                                                            </animations:Implicit.ShowAnimations>
                                                            <animations:Implicit.HideAnimations>
                                                                <animations:OpacityAnimation From="1" To="0" Duration="0:0:0.14" />
                                                            </animations:Implicit.HideAnimations>
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="{x:Bind Name}"
                                                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           TextWrapping="NoWrap" />
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <TextBlock Text="{x:Bind StatusMessage}"
                                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                    <TextBlock Text="·"
                                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                               Visibility="{x:Bind HasMatchSummary}" />
                                                                    <TextBlock Text="{x:Bind MatchSummary}"
                                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                               Visibility="{x:Bind HasMatchSummary}" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <!-- Chevron strip: the entire card-width band between the last rule chip
                                             and the card's bottom edge is the click target, not just the icon.
                                             Height + margins net out the parent StackPanel's 4px spacing so the
                                             strip adds zero layout height to the card - otherwise sibling cards
                                             on the same row would shrink by a few px when this one expands (the
                                             row baseline drops because the expanded card is excluded from it).
                                             Tag carries the DeviceCard since ItemsRepeater doesn't propagate
                                             DataContext to template children. Hover/press swap to the Subtle
                                             theme brushes for a faint affordance; CornerRadius hugs the card's
                                             bottom corners so the hover wash doesn't poke past the card edge. -->
                                        <Button HorizontalAlignment="Stretch"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Padding="0"
                                                MinHeight="0"
                                                Height="16"
                                                Margin="0,-4,0,0"
                                                CornerRadius="0,0,8,8"
                                                Tag="{x:Bind}"
                                                Click="OnRulesExpandToggle"
                                                Visibility="{x:Bind HasMultipleRules, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                ToolTipService.ToolTip="{x:Bind RulesExpandTooltip, Mode=OneWay}">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                                                <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
                                                <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
                                                <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                                <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                                            </Button.Resources>
                                            <FontIcon Glyph="{x:Bind RulesExpandGlyph, Mode=OneWay}"
                                                      FontSize="10"
                                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Text="No rules target this device."
                                               Style="{StaticResource MutedCaptionTextStyle}"
                                               Visibility="{x:Bind HasNoRules}" />

                                    <!-- Apps row sits BELOW the rules section so chevron-style expanders on
                                         rules don't have to fight an apps-section overlay above them. Visible
                                         on render cards only (HasApps stays false on capture). Each chip is the
                                         application's icon with a thin peak-level underbar; tooltip carries
                                         display name + executable path. Implicit show/hide animations fade
                                         chips in when a session appears and out when it closes so the row
                                         doesn't pop. The card-level Border carries AllowDrop+DragOver+Drop to
                                         receive the chip; the chip itself is a drag source (when not
                                         rule-locked) and carries PID + source endpoint id in the DataPackage
                                         Text payload. -->
                                    <StackPanel x:Name="AppsSection" Spacing="4" Visibility="{x:Bind HasApps, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ItemsRepeater ItemsSource="{x:Bind Apps}">
                                            <ItemsRepeater.Layout>
                                                <controls:WrapByRowLayout MinItemWidth="32" ColumnSpacing="4" RowSpacing="6" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AppChip">
                                                    <Border Width="32" Height="40"
                                                            Background="Transparent"
                                                            Padding="0"
                                                            Opacity="{x:Bind ChipOpacity}"
                                                            CanDrag="{x:Bind CanDrag}"
                                                            Tag="{x:Bind}"
                                                            DragStarting="OnAppChipDragStarting"
                                                            DropCompleted="OnAppChipDropCompleted"
                                                            ToolTipService.ToolTip="{x:Bind Tooltip}">
                                                        <animations:Implicit.ShowAnimations>
                                                            <animations:OpacityAnimation Duration="0:0:0.18" From="0" To="1" />
                                                        </animations:Implicit.ShowAnimations>
                                                        <animations:Implicit.HideAnimations>
                                                            <animations:OpacityAnimation Duration="0:0:0.14" From="1" To="0" />
                                                        </animations:Implicit.HideAnimations>
                                                        <Grid RowSpacing="2">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <Grid Grid.Row="0">
                                                                <FontIcon Glyph="&#xECAA;" FontSize="26"
                                                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                          Visibility="{x:Bind HasNoIcon, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                <Image Source="{x:Bind Icon, Mode=OneWay}"
                                                                       Stretch="Uniform"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{x:Bind HasIcon, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            </Grid>

                                                            <Border Grid.Row="1" Height="3" CornerRadius="1.5"
                                                                    Background="{ThemeResource ControlAltFillColorTertiaryBrush}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="{x:Bind PeakBarLeftStars, Mode=OneWay}" />
                                                                        <ColumnDefinition Width="{x:Bind PeakBarRightStars, Mode=OneWay}" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0"
                                                                            Background="{x:Bind PeakLevel, Mode=OneWay, Converter={StaticResource PeakLevelToBrushConverter}}"
                                                                            CornerRadius="1.5" />
                                                                </Grid>
                                                            </Border>

                                                            <Border Grid.Row="0"
                                                                    Background="{ThemeResource SmokeFillColorDefaultBrush}"
                                                                    CornerRadius="6"
                                                                    Width="14" Height="14"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="0,-3,-3,0"
                                                                    ToolTipService.ToolTip="{x:Bind LockTooltip}"
                                                                    Visibility="{x:Bind IsRuleLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <FontIcon Glyph="&#xE72E;"
                                                                          FontSize="8"
                                                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
