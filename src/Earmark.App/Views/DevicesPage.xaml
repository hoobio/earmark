<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Earmark.App.Views.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Earmark.App.ViewModels"
    xmlns:models="using:Earmark.Core.Models"
    Background="Transparent">

    <Grid Padding="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,16">
            <TextBlock Text="Devices" Style="{StaticResource PageHeaderTextStyle}" />
            <Button Content="Refresh" Command="{x:Bind ViewModel.RefreshCommand}" VerticalAlignment="Center" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="20">

                <StackPanel Spacing="8">
                    <TextBlock Text="Output" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Render}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:AudioEndpoint">
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE7F6;" FontSize="20" />
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind FriendlyName}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{x:Bind DeviceDescription}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="6,2"
                                                    Visibility="{x:Bind IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Default" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,2"
                                                    Visibility="{x:Bind IsDefaultCommunications, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Comms" Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{x:Bind State}" Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Input" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Capture}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:AudioEndpoint">
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE720;" FontSize="20" />
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind FriendlyName}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{x:Bind DeviceDescription}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{x:Bind State}" Style="{StaticResource CaptionTextBlockStyle}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
