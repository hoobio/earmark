<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Earmark.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Earmark.App"
    Title="Earmark"
    mc:Ignorable="d">

    <!-- The backdrop (Mica / Acrylic / Solid) is applied in code rather than via
         <Window.SystemBackdrop> so its tint can follow the app's Theme setting, not just the OS,
         and so the user can switch material at runtime. See MainWindow.xaml.cs. -->
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Opaque fill shown only in Solid backdrop mode (no Mica/Acrylic controller attached).
             Painted via ThemeResource so it re-resolves on a theme switch; collapsed otherwise so
             the system backdrop shows through. -->
        <Border x:Name="SolidBackdrop"
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                Visibility="Collapsed" />

        <!-- Only AppTitleBarDragRegion is handed to SetTitleBar. The pane toggle must NOT be
             parented under it: the system treats the SetTitleBar element as the caption and
             swallows pointer input to any control inside it, which made the toggle drop clicks
             (including mid-animation). Keeping the button a sibling leaves it in the client area
             so it always receives input. -->
        <Grid x:Name="AppTitleBar" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="PaneToggleButton"
                    Grid.Column="0"
                    Click="OnPaneToggleClick"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    CornerRadius="0"
                    Width="48"
                    Height="32"
                    Padding="0"
                    ToolTipService.ToolTip="Toggle navigation">
                <FontIcon Glyph="&#xE700;" FontSize="14" />
            </Button>

            <Grid x:Name="AppTitleBarDragRegion"
                  Grid.Column="1"
                  Background="Transparent">
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="Earmark"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Audio rules engine"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <!-- "Update available" pill. A sibling of (not parented under) AppTitleBarDragRegion so
                 it stays in the client area and receives clicks - the SetTitleBar element swallows
                 pointer input. Its right margin is set in code from TitleBar.RightInset so it never
                 slides under the system caption buttons. Hidden unless an update is found. -->
            <Button x:Name="UpdateButton"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Height="28"
                    Padding="10,0"
                    Margin="0,0,144,0"
                    Visibility="Collapsed"
                    Style="{ThemeResource AccentButtonStyle}"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    Click="OnUpdateButtonClick"
                    ToolTipService.ToolTip="A new version of Earmark is available. Click to view the release.">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE896;" FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                    <TextBlock Text="Update available"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="False"
            PaneDisplayMode="Auto"
            OpenPaneLength="220"
            CompactModeThresholdWidth="640"
            ExpandedModeThresholdWidth="1024"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Devices" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF4C3;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Rules" Tag="Rules">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sessions" Tag="Sessions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame">
                <!-- NavigationService swaps pages via Content= (DI singletons), so there's no
                     Frame.Navigate transition. A content transition removes the old page at once
                     and animates the new one in, instead of the old tiles ghosting while the new
                     page does its first layout. -->
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Window>
