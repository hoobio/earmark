<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Earmark.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Earmark.App"
    Title="Earmark"
    mc:Ignorable="d">

    <!-- The backdrop (Mica / Acrylic / Solid) is applied in code rather than via
         <Window.SystemBackdrop> so its tint can follow the app's Theme setting, not just the OS,
         and so the user can switch material at runtime. See MainWindow.xaml.cs. -->
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Opaque fill shown only in Solid backdrop mode (no Mica/Acrylic controller attached).
             Painted via ThemeResource so it re-resolves on a theme switch; collapsed otherwise so
             the system backdrop shows through. -->
        <Border x:Name="SolidBackdrop"
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                Visibility="Collapsed" />

        <!-- WinUI TitleBar control (matches WinUI Gallery): Tall height with caption buttons that
             fill it, a built-in animated pane-toggle (waffle) and back button, icon, and title /
             subtitle. The control owns its drag regions and keeps its interactive elements hit-
             testable, so SetTitleBar(AppTitleBar) no longer swallows clicks the way a raw element
             did. Back/forward history is custom (see NavigationService) because pages are swapped
             as DI singletons rather than via Frame.Navigate, so Frame.CanGoBack is never set. -->
        <TitleBar x:Name="AppTitleBar"
                  Grid.Row="0"
                  Title="Earmark"
                  Subtitle="Audio rules engine"
                  IsBackButtonVisible="True"
                  IsBackButtonEnabled="False"
                  IsPaneToggleButtonVisible="True"
                  BackRequested="OnTitleBarBackRequested"
                  PaneToggleRequested="OnTitleBarPaneToggleRequested">
            <TitleBar.Resources>
                <!-- The disabled back button otherwise paints a solid square (ControlFillColorDisabled).
                     We keep it always-visible-but-disabled, so drop that fill; the dimmed glyph
                     (TextFillColorDisabled) is enough to read as disabled. -->
                <SolidColorBrush x:Key="TitleBarBackButtonBackgroundDisabled" Color="Transparent" />
            </TitleBar.Resources>
            <TitleBar.RightHeader>
                <!-- "Update available" pill. The TitleBar reserves room for the system caption
                     buttons, so the RightHeader slot sits clear of them automatically (no manual
                     RightInset math). Hidden unless an update is found. -->
                <Button x:Name="UpdateButton"
                        VerticalAlignment="Center"
                        Height="28"
                        Padding="10,0"
                        Visibility="Collapsed"
                        Style="{ThemeResource AccentButtonStyle}"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Click="OnUpdateButtonClick"
                        ToolTipService.ToolTip="A new version of Earmark is available. Click to view the release.">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE896;" FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                        <TextBlock Text="Update available"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </TitleBar.RightHeader>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="False"
            PaneDisplayMode="Auto"
            OpenPaneLength="220"
            CompactModeThresholdWidth="640"
            ExpandedModeThresholdWidth="1024"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Devices" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF4C3;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Rules" Tag="Rules">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sessions" Tag="Sessions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- NavigationService swaps pages via Content= (DI singletons), so Frame.Navigate's
                 NavigationThemeTransition never fires. The page-in animation lives on each page's
                 Transitions (set in NavigationService.SwapTo) instead. -->
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Instant loading skeleton: a centred ring over the Mica shell, shown from the moment the
             window is activated until the first page navigates (which waits on background init). The
             nav shell paints immediately; this fills the empty content area so startup never reads as
             a blank/black window. HomePage's own loading ring then takes over while its cards build. -->
        <Grid x:Name="LoadingOverlay" Grid.Row="1">
            <ProgressRing IsActive="True"
                          Width="36"
                          Height="36"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
        </Grid>

        <!-- In-app toast: brief, bottom-centred feedback for an interactive action in this window
             (e.g. "couldn't close that app"). Collapsed until ShowToast animates it in, then it
             auto-dismisses. Windows notifications stay reserved for background events the user may
             not be looking at - see INotificationService. -->
        <Border x:Name="ToastHost"
                Grid.Row="0"
                Grid.RowSpan="2"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,32"
                Padding="14,10"
                MaxWidth="440"
                CornerRadius="{StaticResource CardCornerRadius}"
                Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                BorderThickness="1"
                Opacity="0"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTransform" Y="16" />
            </Border.RenderTransform>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE7BA;"
                          FontSize="16"
                          VerticalAlignment="Top"
                          Margin="0,1,0,0"
                          Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                <TextBlock x:Name="ToastText"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           TextWrapping="Wrap"
                           MaxWidth="380"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
