<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Earmark.App.Controls.ExpanderPill"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Filled, rounded pill: arbitrary content on the left, a full-height chevron on the
         right that toggles IsExpanded. See ExpanderPill.xaml.cs for why this is a custom
         control rather than a WinUI Expander. -->
    <Border x:Name="PillRoot"
            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
            Tapped="OnPillTapped">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ContentPresenter x:Name="ContentHost"
                              Grid.Column="0"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              VerticalContentAlignment="Stretch" />

            <!-- Chevron sits in a Border (not a Button): Border.Tapped fires on a single tap,
                 whereas a Button.Click nested in a ListView item needs the item focused first
                 and so swallows the first click. The chevron carries its own grey box (the same
                 grey the Devices chevron sits on via its pill) so it looks identical whether the
                 pill behind it is grey (Devices) or transparent (Rules). PointerEntered/Exited
                 intensify the box on hover. -->
            <Border x:Name="ChevronHost"
                    Grid.Column="1"
                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                    VerticalAlignment="Stretch"
                    Padding="12,0"
                    Tapped="OnChevronTapped"
                    PointerEntered="OnChevronPointerEntered"
                    PointerExited="OnChevronPointerExited">
                <FontIcon x:Name="ChevronIcon"
                          Glyph="&#xE70D;" FontSize="12"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center" />
            </Border>
        </Grid>
    </Border>
</UserControl>
